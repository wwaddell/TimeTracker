@using TimeTracker.Contracts.Admin
@using TimeTracker.Domain.Enums
@inject TimeTracker.Web.Services.TimeTrackerApi Api
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Label" @bind-Value="model.Label" Required="true" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Key" @bind-Value="model.FieldKey" Required="true"
                              Variant="Variant.Outlined" Placeholder="e.g. project_code" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="FieldDataType" Label="Type" @bind-Value="model.DataType" Variant="Variant.Outlined">
                    @foreach (var dt in Enum.GetValues<FieldDataType>())
                    {
                        <MudSelectItem T="FieldDataType" Value="@dt">@dt</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="int?" Label="Role" @bind-Value="model.OrganizationRoleId" Variant="Variant.Outlined">
                    <MudSelectItem T="int?" Value="@((int?)null)">All roles</MudSelectItem>
                    @foreach (var role in Roles)
                    {
                        <MudSelectItem T="int?" Value="@((int?)role.Id)">@role.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField T="int" Label="Sort order" @bind-Value="model.SortOrder" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudCheckBox T="bool" Label="Required" @bind-Value="model.IsRequired" />
                <MudCheckBox T="bool" Label="Active" @bind-Value="model.IsActive" />
            </MudItem>

            @* Type-aware default value. Stored as a string regardless; the input shape
               adapts so the admin can't enter a default that won't validate. *@
            <MudItem xs="12" sm="6">
                @switch (model.DataType)
                {
                    case FieldDataType.Boolean:
                        <MudSelect T="string" @bind-Value="model.DefaultValue" Label="Default value"
                                   Variant="Variant.Outlined" Clearable="true" Placeholder="No default">
                            <MudSelectItem T="string" Value="@((string?)null)">No default (null)</MudSelectItem>
                            <MudSelectItem T="string" Value="@("true")">True</MudSelectItem>
                            <MudSelectItem T="string" Value="@("false")">False</MudSelectItem>
                        </MudSelect>
                        break;
                    case FieldDataType.Select:
                        <MudSelect T="string" @bind-Value="model.DefaultValue" Label="Default value"
                                   Variant="Variant.Outlined" Clearable="true" Placeholder="No default">
                            <MudSelectItem T="string" Value="@((string?)null)">No default</MudSelectItem>
                            @foreach (var opt in model.Options.Where(o => !string.IsNullOrWhiteSpace(o.Value)))
                            {
                                <MudSelectItem T="string" Value="@opt.Value">@(string.IsNullOrEmpty(opt.Label) ? opt.Value : opt.Label)</MudSelectItem>
                            }
                        </MudSelect>
                        break;
                    case FieldDataType.Number:
                        <MudTextField T="string" @bind-Value="model.DefaultValue" Label="Default value"
                                      Variant="Variant.Outlined" Placeholder="No default" InputType="InputType.Number" />
                        break;
                    case FieldDataType.Date:
                        <MudTextField T="string" @bind-Value="model.DefaultValue" Label="Default value (YYYY-MM-DD)"
                                      Variant="Variant.Outlined" Placeholder="No default" />
                        break;
                    default: // Text
                        <MudTextField T="string" @bind-Value="model.DefaultValue" Label="Default value"
                                      Variant="Variant.Outlined" Placeholder="No default" MaxLength="200" />
                        break;
                }
            </MudItem>
        </MudGrid>

        @if (model.DataType == FieldDataType.Select)
        {
            <MudDivider Class="my-3" />
            <div class="d-flex justify-space-between align-center mb-2">
                <MudText Typo="Typo.subtitle1">Options</MudText>
                <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="AddOption">Add option</MudButton>
            </div>
            @if (model.Options.Count == 0)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Add at least one option for a select field.</MudText>
            }
            @foreach (var opt in model.Options)
            {
                <MudGrid Class="align-center mb-1">
                    <MudItem xs="4">
                        <MudTextField T="string" Placeholder="Value" @bind-Value="opt.Value" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudTextField T="string" Placeholder="Label" @bind-Value="opt.Label" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudSelect T="string" @bind-Value="opt.Icon" Clearable="true" Dense="true" Margin="Margin.Dense"
                                   Variant="Variant.Outlined" Placeholder="Icon"
                                   AdornmentIcon="@TimeTracker.Web.Theme.EntryIconPalette.Resolve(opt.Icon)"
                                   Adornment="@(TimeTracker.Web.Theme.EntryIconPalette.Resolve(opt.Icon) is null ? Adornment.None : Adornment.Start)"
                                   ToStringFunc="@TimeTracker.Web.Theme.EntryIconPalette.Display">
                            @foreach (var c in TimeTracker.Web.Theme.EntryIconPalette.Choices)
                            {
                                <MudSelectItem T="string" Value="@c.Key">
                                    <div class="d-flex align-center" style="gap:.5rem">
                                        <MudIcon Icon="@c.Icon" Size="Size.Small" /> @c.Display
                                    </div>
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="1">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => RemoveOption(opt))" />
                    </MudItem>
                </MudGrid>
            }
        }

        @if (error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="saving">
            @(saving ? "Saving…" : "Save field")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int OrgId { get; set; }
    [Parameter] public IReadOnlyList<OrganizationRoleDto> Roles { get; set; } = [];

    /// <summary>The field being edited; null = create a new field.</summary>
    [Parameter] public EntryFieldAdminDto? Existing { get; set; }

    /// <summary>Default sort order for a new field.</summary>
    [Parameter] public int NextSortOrder { get; set; }

    private FieldEditModel model = new();
    private bool saving;
    private string? error;

    protected override void OnInitialized()
    {
        if (Existing is { } f)
        {
            model = new FieldEditModel
            {
                Id = f.Id,
                FieldKey = f.FieldKey,
                Label = f.Label,
                DataType = f.DataType,
                IsRequired = f.IsRequired,
                SortOrder = f.SortOrder,
                IsActive = f.IsActive,
                OrganizationRoleId = f.OrganizationRoleId,
                DefaultValue = f.DefaultValue,
                Options = f.Options.Select(o => new OptionEditModel { Value = o.Value, Label = o.Label, Icon = o.Icon }).ToList(),
            };
        }
        else
        {
            model = new FieldEditModel { SortOrder = NextSortOrder, IsActive = true, DataType = FieldDataType.Text };
        }
    }

    private void AddOption() => model.Options.Add(new OptionEditModel());

    private void RemoveOption(OptionEditModel opt) => model.Options.Remove(opt);

    private async Task SaveAsync()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(model.Label) || string.IsNullOrWhiteSpace(model.FieldKey))
        {
            error = "Label and key are required.";
            return;
        }

        saving = true;
        try
        {
            var request = new SaveEntryFieldRequest
            {
                FieldKey = model.FieldKey,
                Label = model.Label,
                DataType = model.DataType,
                IsRequired = model.IsRequired,
                SortOrder = model.SortOrder,
                IsActive = model.IsActive,
                OrganizationRoleId = model.OrganizationRoleId,
                DefaultValue = string.IsNullOrWhiteSpace(model.DefaultValue) ? null : model.DefaultValue.Trim(),
                Options = model.Options
                    .Where(o => !string.IsNullOrWhiteSpace(o.Value))
                    .Select((o, i) => new EntryFieldOptionInput(o.Value, o.Label, i + 1, o.Icon))
                    .ToList(),
            };

            var result = Existing is null
                ? await Api.CreateFieldAsync(OrgId, request)
                : await Api.UpdateFieldAsync(OrgId, Existing.Id, request);

            if (result.Success)
            {
                Snackbar.Add(Existing is null ? "Field added" : "Field updated", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                error = result.Error;
            }
        }
        finally
        {
            saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private sealed class FieldEditModel
    {
        public int Id { get; set; }
        public string FieldKey { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public FieldDataType DataType { get; set; } = FieldDataType.Text;
        public bool IsRequired { get; set; }
        public int SortOrder { get; set; }
        public bool IsActive { get; set; } = true;
        public int? OrganizationRoleId { get; set; }
        public string? DefaultValue { get; set; }
        public List<OptionEditModel> Options { get; set; } = new();
    }

    private sealed class OptionEditModel
    {
        public string Value { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string? Icon { get; set; }
    }
}
