@using System.Text.Json
@inject IJSRuntime JS

@*  Report results viewer: paged table + JSON/CSV export. Rows arrive fully loaded (the
    server caps them at 2,000); paging here is purely client-side so the DOM stays light
    while the export still covers everything received. *@
<MudDialog>
    <DialogContent>
        @if (Truncated)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                Results were capped at the first @Rows.Count.ToString("N0") rows. Narrow the
                date range or filters to see everything; exports include only what's shown here.
            </MudAlert>
        }

        <ReportTable Rows="PageRows" />

        @if (TotalPages > 1)
        {
            <div class="d-flex justify-center mt-2">
                @* @(page) not @page — the bare form parses as Razor's @page directive. *@
                <MudPagination Count="@TotalPages" Selected="@(page)" SelectedChanged="@(p => page = p)"
                               Size="Size.Small" BoundaryCount="1" MiddleCount="3" />
            </div>
        }
    </DialogContent>
    <DialogActions>
        @if (Rows.Count > 0)
        {
            <MudButton Variant="Variant.Outlined" Size="Size.Small" Class="me-auto"
                       StartIcon="@Icons.Material.Filled.Download" OnClick="ExportJsonAsync">JSON</MudButton>
            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Download" OnClick="ExportCsvAsync">CSV</MudButton>
        }
        <MudButton Color="Color.Primary" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private const int PageSize = 50;

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired] public IReadOnlyList<object> Rows { get; set; } = [];
    [Parameter] public bool Truncated { get; set; }

    /// <summary>Base filename (no extension) for exports, e.g. "time-detail_2026-06-01_2026-06-09".</summary>
    [Parameter, EditorRequired] public string ExportBaseName { get; set; } = "report";

    private int page = 1;

    private int TotalPages => (int)Math.Ceiling(Rows.Count / (double)PageSize);

    private IReadOnlyList<object> PageRows =>
        Rows.Skip((page - 1) * PageSize).Take(PageSize).ToList();

    private void Close() => MudDialog.Close(DialogResult.Ok(true));

    private async Task ExportJsonAsync()
    {
        var json = JsonSerializer.Serialize(Rows, new JsonSerializerOptions { WriteIndented = true });
        await JS.InvokeVoidAsync("ttDownload", $"{ExportBaseName}.json", "application/json", json);
    }

    private async Task ExportCsvAsync()
    {
        var props = Rows[0].GetType().GetProperties();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine(string.Join(",", props.Select(p => CsvEscape(p.Name))));
        foreach (var row in Rows)
        {
            sb.AppendLine(string.Join(",", props.Select(p => CsvEscape(CsvValue(p.GetValue(row))))));
        }
        await JS.InvokeVoidAsync("ttDownload", $"{ExportBaseName}.csv", "text/csv", sb.ToString());
    }

    private static string CsvValue(object? value) => value switch
    {
        null => "",
        DateOnly d => d.ToString("yyyy-MM-dd"),
        DateTime dt => dt.ToString("o"),
        _ => value.ToString() ?? "",
    };

    private static string CsvEscape(string value) =>
        value.Contains(',') || value.Contains('"') || value.Contains('\n')
            ? $"\"{value.Replace("\"", "\"\"")}\""
            : value;
}
