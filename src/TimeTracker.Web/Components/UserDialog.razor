@using TimeTracker.Contracts.Admin
@using TimeTracker.Contracts.Members
@inject TimeTracker.Web.Services.TimeTrackerApi Api
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @* Email + name are now editable on both invite (new) and edit (existing). For an
           existing user we PUT the profile only when the fields actually changed, so a Save
           that only touched roles doesn't re-write the user row + trigger ModifiedUtc. *@
        <MudTextField T="string" Label="Email" @bind-Value="email" Required="true"
                      MaxLength="320" Counter="320"
                      Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField T="string" Label="Display name" @bind-Value="displayName"
                      MaxLength="200" Counter="200"
                      Variant="Variant.Outlined" Class="mb-3" />

        @* ToStringFunc maps the int role ids to names so the collapsed select reads
           "Administrator, Consultant" instead of "3, 5". *@
        <MudSelect T="int" Label="Roles" MultiSelection="true" @bind-SelectedValues="selectedRoleIds"
                   ToStringFunc="@RoleName"
                   MultiSelectionTextFunc="@(names => string.Join(", ", names))"
                   Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
            @foreach (var role in Roles)
            {
                <MudSelectItem T="int" Value="@role.Id">@role.Name</MudSelectItem>
            }
        </MudSelect>
        @* Selected roles as removable chips — visible at a glance without opening the
           dropdown; the X removes a role directly. *@
        <div class="d-flex flex-wrap mb-3 mt-1" style="gap:.25rem; min-height:1.75rem">
            @foreach (var id in selectedRoleIds)
            {
                <MudChip T="int" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                         OnClose="@(() => RemoveRole(id))">@RoleName(id)</MudChip>
            }
        </div>

        <MudSwitch T="bool" @bind-Value="sendInvite" Color="Color.Primary"
                   Label="@(Existing is null ? "Send invitation email" : "Send invitation email after save")" />
        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">
            @(Existing is null
                ? "On by default for new invites. Turn off to add someone silently."
                : "Off by default. Turn on to (re)send the invite after saving the changes.")
        </MudText>

        @if (error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">@error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="saving">
            @(saving ? "Saving…" : (Existing is null ? "Send invite" : "Save"))
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int OrgId { get; set; }
    [Parameter] public IReadOnlyList<OrganizationRoleDto> Roles { get; set; } = [];

    /// <summary>The member being edited; null = invite a new user.</summary>
    [Parameter] public MemberDto? Existing { get; set; }

    private string email = string.Empty;
    private string displayName = string.Empty;
    private IReadOnlyCollection<int> selectedRoleIds = new HashSet<int>();
    // Invite defaults: on for new (the typical case), off for edit (admin tweaks shouldn't
    // re-mail the user by accident). Either can be toggled in the dialog.
    private bool sendInvite;
    private bool saving;
    private string? error;

    protected override void OnInitialized()
    {
        if (Existing is { } m)
        {
            email = m.Email;
            displayName = m.DisplayName;
            selectedRoleIds = m.Roles.Select(r => r.Id).ToHashSet();
            sendInvite = false;
        }
        else
        {
            sendInvite = true;
        }
    }

    private async Task SaveAsync()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(email) || !email.Contains('@'))
        {
            error = "A valid email is required.";
            return;
        }
        if (Existing is not null && string.IsNullOrWhiteSpace(displayName))
        {
            error = "Display name is required."; // POST allows empty (falls back to email); PUT does not.
            return;
        }

        saving = true;
        try
        {
            if (Existing is null)
            {
                var result = await Api.InviteMemberAsync(OrgId, new InviteMemberRequest
                {
                    Email = email.Trim(),
                    DisplayName = string.IsNullOrWhiteSpace(displayName) ? null : displayName.Trim(),
                    RoleIds = selectedRoleIds.ToList(),
                    SendInvite = sendInvite,
                });
                if (!result.Success) { error = result.Error; return; }
                Snackbar.Add(sendInvite ? "Invitation sent" : "Member added", Severity.Success);
            }
            else
            {
                // Two separate endpoints; only fire each if its slice actually changed. This
                // avoids surprising ModifiedUtc bumps + history rows for clicks that didn't
                // change anything. The sendInvite toggle attaches to the profile call when
                // either is dirty, or to a no-op profile save when nothing else changed.
                var profileChanged = !string.Equals(email.Trim(), Existing.Email, StringComparison.OrdinalIgnoreCase)
                    || !string.Equals(displayName.Trim(), Existing.DisplayName, StringComparison.Ordinal);
                var currentRoles = selectedRoleIds.ToHashSet();
                var existingRoles = Existing.Roles.Select(r => r.Id).ToHashSet();
                var rolesChanged = !currentRoles.SetEquals(existingRoles);

                if (profileChanged || sendInvite)
                {
                    var pResult = await Api.UpdateMemberProfileAsync(OrgId, Existing.UserId, new UpdateMemberProfileRequest
                    {
                        Email = email.Trim(),
                        DisplayName = displayName.Trim(),
                        SendInvite = sendInvite,
                    });
                    if (!pResult.Success) { error = pResult.Error; return; }
                }
                if (rolesChanged)
                {
                    var rResult = await Api.SetMemberRolesAsync(OrgId, Existing.UserId, new SetMemberRolesRequest
                    {
                        RoleIds = selectedRoleIds.ToList(),
                    });
                    if (!rResult.Success) { error = rResult.Error; return; }
                }
                if (!profileChanged && !rolesChanged && !sendInvite)
                {
                    Snackbar.Add("No changes.", Severity.Info);
                    MudDialog.Close(DialogResult.Cancel());
                    return;
                }
                Snackbar.Add(sendInvite ? "Saved and invitation sent" : "Saved", Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        finally
        {
            saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private string RoleName(int id) => Roles.FirstOrDefault(r => r.Id == id)?.Name ?? id.ToString();

    private void RemoveRole(int id) => selectedRoleIds = selectedRoleIds.Where(x => x != id).ToHashSet();
}
