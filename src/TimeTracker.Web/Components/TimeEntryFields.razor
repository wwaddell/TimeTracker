@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Contracts.Tasks
@using TimeTracker.Domain.Enums
@using TimeTracker.Web.Models

<MudTextField T="string" Label="Note" @bind-Value="Model.Note" Lines="2" AutoGrow="true" MaxLines="12"
              Required="true" Immediate="true" Variant="Variant.Outlined" Class="mb-3"
              Placeholder="What did you work on?" />

<MudGrid>
    <MudItem xs="12" sm="4">
        <MudDatePicker Label="Date" @bind-Date="DateProxy" Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudTimePicker Label="Start time" @bind-Time="TimeProxy" Variant="Variant.Outlined" />
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudNumericField T="int?" Label="Duration (min)" @bind-Value="Model.DurationMinutes"
                         Min="0" Variant="Variant.Outlined" />
    </MudItem>
</MudGrid>

@if (Tasks is { Count: > 0 })
{
    <MudSelect T="int?" Label="Task" @bind-Value="Model.TaskId" Clearable="true"
               Variant="Variant.Outlined" Class="mt-3" ToStringFunc="@TaskToString">
        @foreach (var task in Tasks)
        {
            <MudSelectItem T="int?" Value="@((int?)task.Id)">
                <div class="d-flex flex-column py-1">
                    <MudText Typo="Typo.body2">@task.Title</MudText>
                    @if (!string.IsNullOrWhiteSpace(task.Description))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@Truncate(task.Description, 90)</MudText>
                    }
                </div>
            </MudSelectItem>
        }
    </MudSelect>
}

@if (Fields is { Count: > 0 })
{
    <MudDivider Class="my-4" />
    <MudGrid>
        @foreach (var field in Fields)
        {
            <MudItem xs="12" sm="6">
                @switch (field.DataType)
                {
                    case FieldDataType.Boolean:
                        <MudCheckBox T="bool" Label="@field.Label"
                                     Value="@IsTrue(field.Id)"
                                     ValueChanged="@(v => SetValue(field.Id, v ? "true" : "false"))" />
                        break;
                    case FieldDataType.Select:
                        <MudSelect T="string" Label="@field.Label" Required="@field.IsRequired"
                                   Variant="Variant.Outlined" Clearable="true"
                                   Value="@GetValue(field.Id)"
                                   ValueChanged="@(v => SetValue(field.Id, v))">
                            @foreach (var opt in field.Options)
                            {
                                <MudSelectItem T="string" Value="@opt.Value">@opt.Label</MudSelectItem>
                            }
                        </MudSelect>
                        break;
                    case FieldDataType.Number:
                        <MudTextField T="string" Label="@field.Label" Required="@field.IsRequired"
                                      Variant="Variant.Outlined" InputType="InputType.Number"
                                      Value="@GetValue(field.Id)"
                                      ValueChanged="@(v => SetValue(field.Id, v))" />
                        break;
                    case FieldDataType.Date:
                        <MudTextField T="string" Label="@field.Label" Required="@field.IsRequired"
                                      Variant="Variant.Outlined" InputType="InputType.Date"
                                      Value="@GetValue(field.Id)"
                                      ValueChanged="@(v => SetValue(field.Id, v))" />
                        break;
                    default:
                        <MudTextField T="string" Label="@field.Label" Required="@field.IsRequired"
                                      Variant="Variant.Outlined"
                                      Value="@GetValue(field.Id)"
                                      ValueChanged="@(v => SetValue(field.Id, v))" />
                        break;
                }
            </MudItem>
        }
    </MudGrid>
}

@code {
    [Parameter, EditorRequired] public TimeEntryModel Model { get; set; } = default!;
    [Parameter] public IReadOnlyList<EntryFieldDto> Fields { get; set; } = [];
    [Parameter] public IReadOnlyList<TaskDto>? Tasks { get; set; }

    // MudDatePicker/MudTimePicker work in DateTime?/TimeSpan?; map to the model's DateOnly/TimeOnly.
    private DateTime? DateProxy
    {
        get => Model.EntryDate.ToDateTime(TimeOnly.MinValue);
        set => Model.EntryDate = value is { } d ? DateOnly.FromDateTime(d) : DateOnly.FromDateTime(DateTime.Now);
    }

    private TimeSpan? TimeProxy
    {
        get => Model.StartTime?.ToTimeSpan();
        set => Model.StartTime = value is { } t ? TimeOnly.FromTimeSpan(t) : null;
    }

    private string? GetValue(int fieldId) => Model.Attributes.TryGetValue(fieldId, out var v) ? v : null;

    private void SetValue(int fieldId, string? value) => Model.Attributes[fieldId] = value;

    private bool IsTrue(int fieldId) => GetValue(fieldId) == "true";

    // Collapsed selector shows just the task title (not the rich two-line option content).
    private string TaskToString(int? id) =>
        Tasks?.FirstOrDefault(t => t.Id == id)?.Title ?? string.Empty;

    private static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..max].TrimEnd() + "…";
}
