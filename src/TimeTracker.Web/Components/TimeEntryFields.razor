@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Contracts.Tasks
@using TimeTracker.Domain.Enums
@using TimeTracker.Web.Models
@inject TimeTracker.Web.Services.TimeTrackerApi Api

<MudTextField T="string" Label="Note" @bind-Value="Model.Note" Lines="2" AutoGrow="true" MaxLines="12"
              Required="true" Immediate="true" Variant="Variant.Outlined" Class="mb-3"
              Placeholder="What did you work on?" />

<MudGrid>
    <MudItem xs="12" sm="@(RequireTime ? 4 : 6)">
        <MudDatePicker Label="Date" @bind-Date="DateProxy" Variant="Variant.Outlined" />
    </MudItem>
    @if (RequireTime)
    {
        <MudItem xs="12" sm="4">
            <MudTimePicker Label="Start time" @bind-Time="TimeProxy" Variant="Variant.Outlined" />
        </MudItem>
    }
    <MudItem xs="12" sm="@(RequireTime ? 4 : 6)">
        <MudNumericField T="int?" Label="Duration (min)" @bind-Value="Model.DurationMinutes"
                         Min="0" Variant="Variant.Outlined" />
    </MudItem>
</MudGrid>

@if (Tasks is { Count: > 0 })
{
    <MudSelect T="int?" Label="Task" Value="Model.TaskId" ValueChanged="OnTaskChanged" Clearable="true"
               Variant="Variant.Outlined" Class="mt-3" ToStringFunc="@TaskToString">
        @foreach (var task in Tasks)
        {
            <MudSelectItem T="int?" Value="@((int?)task.Id)">
                <div class="d-flex flex-column py-1">
                    <MudText Typo="Typo.body2">@task.Title</MudText>
                    @if (!string.IsNullOrWhiteSpace(task.Description))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@Truncate(task.Description, 90)</MudText>
                    }
                </div>
            </MudSelectItem>
        }
    </MudSelect>

    @if (SelectedTask is { } selected)
    {
        <MudPaper Class="pa-3 mt-2" Outlined="true">
            <div class="d-flex justify-space-between align-center mb-1">
                <MudText Typo="Typo.body2"><b>Task progress</b></MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @if (selected.EstimatedHours is { } est)
                    {
                        <span>@($"{est:0.##}h estimated")</span>
                        @if (RemainingHours is { } rem)
                        {
                            <span> · @($"{rem:0.##}h left")</span>
                        }
                    }
                    else
                    {
                        <span>No estimate</span>
                    }
                </MudText>
            </div>
            <div class="d-flex align-center" style="gap:1rem">
                <MudSlider T="int" Value="taskPercent" ValueChanged="OnPercentChanged"
                           Min="0" Max="100" Step="5" Color="Color.Primary" Class="flex-grow-1" />
                <MudText Typo="Typo.body2" Style="width:3rem; text-align:right"><b>@taskPercent%</b></MudText>
            </div>
            @if (taskPercent != selected.PercentComplete)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Saving this entry updates the task from @selected.PercentComplete% to @taskPercent%@(taskPercent >= 100 ? " (marks it complete)" : "").
                </MudText>
            }
        </MudPaper>
    }
}

@if (Fields is { Count: > 0 })
{
    <MudDivider Class="my-4" />
    <MudGrid>
        @foreach (var field in Fields)
        {
            <MudItem xs="12" sm="6">
                @switch (field.DataType)
                {
                    case FieldDataType.Boolean:
                        <MudCheckBox T="bool" Label="@field.Label"
                                     Value="@IsTrue(field.Id)"
                                     ValueChanged="@(v => SetValue(field.Id, v ? "true" : "false"))" />
                        break;
                    case FieldDataType.Select:
                        <MudSelect T="string" Label="@field.Label" Required="@field.IsRequired"
                                   Variant="Variant.Outlined" Clearable="true"
                                   Value="@GetValue(field.Id)"
                                   ValueChanged="@(v => SetValue(field.Id, v))">
                            @foreach (var opt in field.Options)
                            {
                                <MudSelectItem T="string" Value="@opt.Value">@opt.Label</MudSelectItem>
                            }
                        </MudSelect>
                        break;
                    case FieldDataType.Number:
                        <MudTextField T="string" Label="@field.Label" Required="@field.IsRequired"
                                      Variant="Variant.Outlined" InputType="InputType.Number"
                                      Value="@GetValue(field.Id)"
                                      ValueChanged="@(v => SetValue(field.Id, v))" />
                        break;
                    case FieldDataType.Date:
                        <MudTextField T="string" Label="@field.Label" Required="@field.IsRequired"
                                      Variant="Variant.Outlined" InputType="InputType.Date"
                                      Value="@GetValue(field.Id)"
                                      ValueChanged="@(v => SetValue(field.Id, v))" />
                        break;
                    default:
                        <MudTextField T="string" Label="@field.Label" Required="@field.IsRequired"
                                      Variant="Variant.Outlined"
                                      Value="@GetValue(field.Id)"
                                      ValueChanged="@(v => SetValue(field.Id, v))" />
                        break;
                }
            </MudItem>
        }
    </MudGrid>
}

@code {
    [Parameter, EditorRequired] public TimeEntryModel Model { get; set; } = default!;
    [Parameter] public IReadOnlyList<EntryFieldDto> Fields { get; set; } = [];
    [Parameter] public IReadOnlyList<TaskDto>? Tasks { get; set; }
    [Parameter] public int OrgId { get; set; }

    /// <summary>When false, the org captures date only — the time field is hidden and cleared.</summary>
    [Parameter] public bool RequireTime { get; set; } = true;

    // Editable copy of the selected task's completion %, kept in sync with the picker.
    private int taskPercent;
    private int? syncedTaskId;
    private bool progressSynced;

    private TaskDto? SelectedTask => Tasks?.FirstOrDefault(t => t.Id == Model.TaskId);

    // Remaining = estimate scaled by the portion not yet complete.
    private decimal? RemainingHours =>
        SelectedTask?.EstimatedHours is { } est ? Math.Round(est * (100 - taskPercent) / 100m, 2) : null;

    protected override void OnParametersSet()
    {
        if (!RequireTime)
        {
            Model.StartTime = null;
        }

        // Sync the editable percent from the task when the selection identity changes
        // (e.g. opening an existing entry), without clobbering an in-progress edit.
        if (!progressSynced || syncedTaskId != Model.TaskId)
        {
            progressSynced = true;
            syncedTaskId = Model.TaskId;
            taskPercent = SelectedTask?.PercentComplete ?? 0;
        }
    }

    private void OnTaskChanged(int? taskId)
    {
        Model.TaskId = taskId;
        syncedTaskId = taskId;
        taskPercent = SelectedTask?.PercentComplete ?? 0;
    }

    private void OnPercentChanged(int value) => taskPercent = value;

    /// <summary>
    /// Persists the adjusted task progress if it changed. Called by the entry dialog on save.
    /// Reaching 100% marks the task complete (remembering the prior % to restore on reopen).
    /// </summary>
    public async Task PersistTaskProgressAsync()
    {
        if (SelectedTask is not { } task || taskPercent == task.PercentComplete)
        {
            return;
        }

        var complete = taskPercent >= 100;
        await Api.UpdateTaskAsync(OrgId, task.Id, new SaveTaskRequest
        {
            Title = task.Title,
            Description = task.Description,
            EstimatedHours = task.EstimatedHours,
            IsComplete = complete,
            PercentComplete = taskPercent,
            PercentBeforeComplete = complete ? task.PercentComplete : null,
        });
    }

    // MudDatePicker/MudTimePicker work in DateTime?/TimeSpan?; map to the model's DateOnly/TimeOnly.
    private DateTime? DateProxy
    {
        get => Model.EntryDate.ToDateTime(TimeOnly.MinValue);
        set => Model.EntryDate = value is { } d ? DateOnly.FromDateTime(d) : DateOnly.FromDateTime(DateTime.Now);
    }

    private TimeSpan? TimeProxy
    {
        get => Model.StartTime?.ToTimeSpan();
        set => Model.StartTime = value is { } t ? TimeOnly.FromTimeSpan(t) : null;
    }

    private string? GetValue(int fieldId) => Model.Attributes.TryGetValue(fieldId, out var v) ? v : null;

    private void SetValue(int fieldId, string? value) => Model.Attributes[fieldId] = value;

    private bool IsTrue(int fieldId) => GetValue(fieldId) == "true";

    // Collapsed selector shows just the task title (not the rich two-line option content).
    private string TaskToString(int? id) =>
        Tasks?.FirstOrDefault(t => t.Id == id)?.Title ?? string.Empty;

    private static string Truncate(string text, int max) =>
        text.Length <= max ? text : text[..max].TrimEnd() + "…";
}
