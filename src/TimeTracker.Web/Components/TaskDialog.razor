@using TimeTracker.Contracts.Members
@using TimeTracker.Contracts.Projects
@using TimeTracker.Contracts.Tasks
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Domain.Enums
@inject TimeTracker.Web.Services.TimeTrackerApi Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        @* Tabs: Details (always) + History (only when editing an existing task — there's no
           history for a not-yet-created task). Loading the history happens on tab activation. *@
        <MudTabs Elevation="0" Rounded="true" KeepPanelsAlive="true" ActivePanelIndexChanged="OnTabChanged">
            <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.Edit">
        @* Lengths mirror TaskItemConfiguration HasMaxLength so the browser caps input before
           the API gets a chance to reject it. Counter shows remaining chars as you type. *@
        <MudTextField T="string" Label="Title" @bind-Value="title" Required="true"
                      MaxLength="200" Counter="200"
                      Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField T="string" Label="Description" @bind-Value="description" Lines="2"
                      MaxLength="2000" Counter="2000"
                      AutoGrow="true" MaxLines="10" Variant="Variant.Outlined" />
        @* Pop-out editor for long descriptions: the inline field caps at 10 visible lines,
           so once text grows past that, editing in place gets cramped. Minimal link per
           design — bottom-left under the field. *@
        <div class="d-flex mb-3">
            <MudLink Typo="Typo.caption" OnClick="ExpandDescriptionAsync" Style="cursor:pointer">
                <MudIcon Icon="@Icons.Material.Filled.OpenInFull" Size="Size.Small"
                         Style="font-size:0.9rem; vertical-align:text-bottom" />
                Open in larger editor
            </MudLink>
        </div>
        @if (Projects is { Count: > 0 })
        {
            <MudSelect T="int?" Label="Project" @bind-Value="projectId" Clearable="true"
                       Variant="Variant.Outlined" Class="mb-3" Placeholder="No project">
                @foreach (var p in Projects)
                {
                    <MudSelectItem T="int?" Value="@((int?)p.Id)">@p.Name</MudSelectItem>
                }
            </MudSelect>
        }
        @if (Members is { Count: > 0 })
        {
            <MudSelect T="int" Label="Assigned to" @bind-Value="assignedToUserId" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var m in Members)
                {
                    <MudSelectItem T="int" Value="@m.UserId">
                        @m.DisplayName@(m.IsPending ? " (pending)" : "")
                    </MudSelectItem>
                }
            </MudSelect>
        }
        <MudGrid Class="mb-3">
            <MudItem xs="12" sm="5">
                <MudTextField T="string" Label="Reference code" @bind-Value="referenceCode"
                              Variant="Variant.Outlined" Placeholder="e.g. JIRA-123" />
            </MudItem>
            <MudItem xs="12" sm="7">
                <MudTextField T="string" Label="External URL" @bind-Value="externalUrl"
                              Variant="Variant.Outlined" InputType="InputType.Url" Placeholder="https://…" />
            </MudItem>
        </MudGrid>
        <MudGrid Class="mb-3">
            <MudItem xs="12" sm="4">
                <MudSelect T="TaskPriority?" Label="Priority" @bind-Value="priority" Clearable="true" Variant="Variant.Outlined">
                    @foreach (var p in Enum.GetValues<TaskPriority>())
                    {
                        <MudSelectItem T="TaskPriority?" Value="@p">@p</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudDatePicker Label="Due date" @bind-Date="dueDate" Variant="Variant.Outlined" Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField T="decimal?" Label="Estimated hours" @bind-Value="estimatedHours"
                                 Min="0" Step="0.25M" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
        <MudText Typo="Typo.body2">% complete: <b>@percentComplete%</b></MudText>
        <MudSlider T="int" @bind-Value="percentComplete" Min="0" Max="100" Step="5" Color="Color.Primary"
                   Disabled="isComplete" />
        @if (isComplete)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Completed tasks are 100%. Uncheck to adjust.</MudText>
        }
        <MudCheckBox T="bool" Label="Complete" Value="isComplete" ValueChanged="OnCompleteChanged" Class="mt-2" />
        @if (error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@error</MudAlert>
        }
            </MudTabPanel>
            @if (Existing is not null)
            {
                <MudTabPanel Text="History" Icon="@Icons.Material.Filled.History">
                    @if (history is null)
                    {
                        <MudProgressLinear Indeterminate="true" />
                    }
                    else if (history.Count == 0)
                    {
                        <MudText Class="mud-text-secondary">No history yet.</MudText>
                    }
                    else
                    {
                        <MudStack Spacing="1">
                            @foreach (var h in history)
                            {
                                <MudPaper Outlined="true" Class="pa-2 d-flex align-center" Elevation="0" Style="gap:.6rem">
                                    <MudIcon Icon="@HistoryIcon(h.ChangeType)" Color="@HistoryColor(h.ChangeType)" Size="Size.Small" />
                                    <div class="flex-grow-1" style="min-width:0">
                                        <MudText Typo="Typo.body2">@HistoryLine(h)</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            @h.ChangedUtc.ToLocalTime().ToString("MMM d, yyyy · HH:mm")
                                            @(h.ChangedByName is null ? " · system" : $" · {h.ChangedByName}")
                                        </MudText>
                                    </div>
                                </MudPaper>
                            }
                        </MudStack>
                    }
                </MudTabPanel>
            }
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="saving">
            @(saving ? "Saving…" : "Save task")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int OrgId { get; set; }
    [Parameter] public TaskDto? Existing { get; set; }

    /// <summary>Projects the current user can pick (caller fetches via GetVisibleProjectsAsync).</summary>
    [Parameter] public IReadOnlyList<ProjectPickerDto> Projects { get; set; } = [];

    /// <summary>Org members for the assignee picker.</summary>
    [Parameter] public IReadOnlyList<MemberDto> Members { get; set; } = [];

    /// <summary>Default assignee on a new task (the current user).</summary>
    [Parameter] public int CurrentUserId { get; set; }

    private string title = string.Empty;
    private string? description;
    private bool isComplete;
    private decimal? estimatedHours;
    private int percentComplete;
    private int priorPercent;
    private TaskPriority? priority;
    private DateTime? dueDate;
    private int? projectId;
    private string? referenceCode;
    private string? externalUrl;
    private int assignedToUserId;
    private bool saving;
    private string? error;

    protected override void OnInitialized()
    {
        if (Existing is { } t)
        {
            title = t.Title;
            description = t.Description;
            isComplete = t.IsComplete;
            estimatedHours = t.EstimatedHours;
            percentComplete = t.PercentComplete;
            priorPercent = t.PercentBeforeComplete ?? t.PercentComplete;
            priority = t.Priority;
            dueDate = t.DueDate?.ToDateTime(TimeOnly.MinValue);
            projectId = t.ProjectId;
            referenceCode = t.ReferenceCode;
            externalUrl = t.ExternalUrl;
            assignedToUserId = t.AssignedToUserId;
        }
        else
        {
            // New task → default to the current user (who must be in the members list).
            assignedToUserId = CurrentUserId;
        }
    }

    // Pop the description into a full-size editor dialog; OK copies the text back.
    private async Task ExpandDescriptionAsync()
    {
        var parameters = new DialogParameters<TextExpandDialog>
        {
            { x => x.Label, "Description" },
            { x => x.Value, description },
            { x => x.MaxLength, 2000 },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<TextExpandDialog>("Edit description", parameters, options);
        if (await dialog.Result is { Canceled: false, Data: string edited })
        {
            description = edited;
            StateHasChanged();
        }
    }

    private async Task SaveAsync()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(title))
        {
            error = "A title is required.";
            return;
        }

        saving = true;
        try
        {
            var request = new SaveTaskRequest
            {
                Title = title,
                Description = description,
                IsComplete = isComplete,
                EstimatedHours = estimatedHours,
                PercentComplete = percentComplete,
                PercentBeforeComplete = isComplete ? priorPercent : null,
                Priority = priority,
                DueDate = dueDate is { } d ? DateOnly.FromDateTime(d) : null,
                ProjectId = projectId,
                ReferenceCode = referenceCode,
                ExternalUrl = externalUrl,
                AssignedToUserId = assignedToUserId,
            };
            var result = Existing is null
                ? await Api.CreateTaskAsync(OrgId, request)
                : await Api.UpdateTaskAsync(OrgId, Existing.Id, request);

            if (result.Success)
            {
                Snackbar.Add(Existing is null ? "Task added" : "Task updated", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                error = result.Error;
            }
        }
        finally
        {
            saving = false;
        }
    }

    private void OnCompleteChanged(bool value)
    {
        isComplete = value;
        if (value)
        {
            priorPercent = percentComplete; // remember where it was
            percentComplete = 100;          // completing snaps to 100%
        }
        else
        {
            percentComplete = priorPercent; // reopening restores the prior %, then editable
        }
    }

    private void Cancel() => MudDialog.Cancel();

    // --- History tab ---
    // Lazy-loaded once on first activation. KeepPanelsAlive on the parent MudTabs keeps the
    // list around for subsequent tab switches without re-fetching.
    private IReadOnlyList<TaskHistoryDto>? history;

    private async Task OnTabChanged(int index)
    {
        if (index == 1 && history is null && Existing is not null)
        {
            try
            {
                history = await Api.GetTaskHistoryAsync(OrgId, Existing.Id);
            }
            catch
            {
                history = []; // soft-fail; the empty-state message renders
            }
        }
    }

    private static string HistoryIcon(string type) => type switch
    {
        "Created" => Icons.Material.Filled.AddCircleOutline,
        "Updated" => Icons.Material.Filled.Edit,
        "Deleted" => Icons.Material.Filled.DeleteOutline,
        "Restored" => Icons.Material.Filled.RestoreFromTrash,
        _ => Icons.Material.Filled.Circle,
    };

    private static Color HistoryColor(string type) => type switch
    {
        "Created" => Color.Success,
        "Updated" => Color.Info,
        "Deleted" => Color.Error,
        "Restored" => Color.Warning,
        _ => Color.Default,
    };

    private static string HistoryLine(TaskHistoryDto h) => h.ChangeType switch
    {
        "Created" => "Task created",
        "Deleted" => "Task deleted",
        "Restored" => "Task restored",
        "Updated" => h.FieldName switch
        {
            null => "Updated",
            _ => $"{Humanize(h.FieldName)}: {Display(h.OldValue)} → {Display(h.NewValue)}",
        },
        _ => h.ChangeType,
    };

    // "AssignedToUserId" → "Assigned to user id". Cheap and good enough for now; could map
    // a few CLR names to friendlier labels (e.g. "AssignedToUserId" → "Assignee") if needed.
    private static string Humanize(string camel)
    {
        if (string.IsNullOrEmpty(camel)) return camel;
        var sb = new System.Text.StringBuilder(camel.Length + 4);
        for (var i = 0; i < camel.Length; i++)
        {
            if (i > 0 && char.IsUpper(camel[i]) && !char.IsUpper(camel[i - 1]))
            {
                sb.Append(' ');
                sb.Append(char.ToLowerInvariant(camel[i]));
            }
            else
            {
                sb.Append(i == 0 ? camel[i] : char.ToLowerInvariant(camel[i]));
            }
        }
        return sb.ToString();
    }

    private static string Display(string? v) => string.IsNullOrEmpty(v) ? "(empty)" : v;
}
