@using TimeTracker.Contracts.Members
@using TimeTracker.Contracts.Projects
@using TimeTracker.Contracts.Tasks
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Domain.Enums
@inject TimeTracker.Web.Services.TimeTrackerApi Api
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTextField T="string" Label="Title" @bind-Value="title" Required="true"
                      Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField T="string" Label="Description" @bind-Value="description" Lines="2"
                      AutoGrow="true" MaxLines="10" Variant="Variant.Outlined" Class="mb-3" />
        @if (Projects is { Count: > 0 })
        {
            <MudSelect T="int?" Label="Project" @bind-Value="projectId" Clearable="true"
                       Variant="Variant.Outlined" Class="mb-3" Placeholder="No project">
                @foreach (var p in Projects)
                {
                    <MudSelectItem T="int?" Value="@((int?)p.Id)">@p.Name</MudSelectItem>
                }
            </MudSelect>
        }
        @if (Members is { Count: > 0 })
        {
            <MudSelect T="int" Label="Assigned to" @bind-Value="assignedToUserId" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var m in Members)
                {
                    <MudSelectItem T="int" Value="@m.UserId">
                        @m.DisplayName@(m.IsPending ? " (pending)" : "")
                    </MudSelectItem>
                }
            </MudSelect>
        }
        <MudGrid Class="mb-3">
            <MudItem xs="12" sm="5">
                <MudTextField T="string" Label="Reference code" @bind-Value="referenceCode"
                              Variant="Variant.Outlined" Placeholder="e.g. JIRA-123" />
            </MudItem>
            <MudItem xs="12" sm="7">
                <MudTextField T="string" Label="External URL" @bind-Value="externalUrl"
                              Variant="Variant.Outlined" InputType="InputType.Url" Placeholder="https://…" />
            </MudItem>
        </MudGrid>
        <MudGrid Class="mb-3">
            <MudItem xs="12" sm="4">
                <MudSelect T="TaskPriority?" Label="Priority" @bind-Value="priority" Clearable="true" Variant="Variant.Outlined">
                    @foreach (var p in Enum.GetValues<TaskPriority>())
                    {
                        <MudSelectItem T="TaskPriority?" Value="@p">@p</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudDatePicker Label="Due date" @bind-Date="dueDate" Variant="Variant.Outlined" Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField T="decimal?" Label="Estimated hours" @bind-Value="estimatedHours"
                                 Min="0" Step="0.25M" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
        <MudText Typo="Typo.body2">% complete: <b>@percentComplete%</b></MudText>
        <MudSlider T="int" @bind-Value="percentComplete" Min="0" Max="100" Step="5" Color="Color.Primary"
                   Disabled="isComplete" />
        @if (isComplete)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Completed tasks are 100%. Uncheck to adjust.</MudText>
        }
        <MudCheckBox T="bool" Label="Complete" Value="isComplete" ValueChanged="OnCompleteChanged" Class="mt-2" />
        @if (error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="saving">
            @(saving ? "Saving…" : "Save task")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int OrgId { get; set; }
    [Parameter] public TaskDto? Existing { get; set; }

    /// <summary>Projects the current user can pick (caller fetches via GetVisibleProjectsAsync).</summary>
    [Parameter] public IReadOnlyList<ProjectPickerDto> Projects { get; set; } = [];

    /// <summary>Org members for the assignee picker.</summary>
    [Parameter] public IReadOnlyList<MemberDto> Members { get; set; } = [];

    /// <summary>Default assignee on a new task (the current user).</summary>
    [Parameter] public int CurrentUserId { get; set; }

    private string title = string.Empty;
    private string? description;
    private bool isComplete;
    private decimal? estimatedHours;
    private int percentComplete;
    private int priorPercent;
    private TaskPriority? priority;
    private DateTime? dueDate;
    private int? projectId;
    private string? referenceCode;
    private string? externalUrl;
    private int assignedToUserId;
    private bool saving;
    private string? error;

    protected override void OnInitialized()
    {
        if (Existing is { } t)
        {
            title = t.Title;
            description = t.Description;
            isComplete = t.IsComplete;
            estimatedHours = t.EstimatedHours;
            percentComplete = t.PercentComplete;
            priorPercent = t.PercentBeforeComplete ?? t.PercentComplete;
            priority = t.Priority;
            dueDate = t.DueDate?.ToDateTime(TimeOnly.MinValue);
            projectId = t.ProjectId;
            referenceCode = t.ReferenceCode;
            externalUrl = t.ExternalUrl;
            assignedToUserId = t.AssignedToUserId;
        }
        else
        {
            // New task → default to the current user (who must be in the members list).
            assignedToUserId = CurrentUserId;
        }
    }

    private async Task SaveAsync()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(title))
        {
            error = "A title is required.";
            return;
        }

        saving = true;
        try
        {
            var request = new SaveTaskRequest
            {
                Title = title,
                Description = description,
                IsComplete = isComplete,
                EstimatedHours = estimatedHours,
                PercentComplete = percentComplete,
                PercentBeforeComplete = isComplete ? priorPercent : null,
                Priority = priority,
                DueDate = dueDate is { } d ? DateOnly.FromDateTime(d) : null,
                ProjectId = projectId,
                ReferenceCode = referenceCode,
                ExternalUrl = externalUrl,
                AssignedToUserId = assignedToUserId,
            };
            var result = Existing is null
                ? await Api.CreateTaskAsync(OrgId, request)
                : await Api.UpdateTaskAsync(OrgId, Existing.Id, request);

            if (result.Success)
            {
                Snackbar.Add(Existing is null ? "Task added" : "Task updated", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                error = result.Error;
            }
        }
        finally
        {
            saving = false;
        }
    }

    private void OnCompleteChanged(bool value)
    {
        isComplete = value;
        if (value)
        {
            priorPercent = percentComplete; // remember where it was
            percentComplete = 100;          // completing snaps to 100%
        }
        else
        {
            percentComplete = priorPercent; // reopening restores the prior %, then editable
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
