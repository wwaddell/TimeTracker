@using TimeTracker.Contracts.Projects
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Contracts.Tasks
@using TimeTracker.Web.Models
@inject TimeTracker.Web.Services.TimeTrackerApi Api
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <TimeEntryFields @ref="entryFields" Model="model" Fields="Fields" Tasks="Tasks" Projects="Projects"
                         OrgId="OrgId" RequireTime="RequireTime" />
        @if (Entry is not null && MissingRequired() is { Count: > 0 } missing)
        {
            <MudAlert Severity="Severity.Info" Class="mt-3" Dense="true">
                You can save now — this entry stays flagged incomplete until you fill: @string.Join(", ", missing)
            </MudAlert>
        }
        @if (error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        @if (Entry is not null)
        {
            <MudButton Color="Color.Error" OnClick="DeleteAsync" Disabled="saving" Class="me-auto">Delete</MudButton>
        }
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="saving">
            @(saving ? "Saving…" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public int OrgId { get; set; }
    [Parameter] public IReadOnlyList<EntryFieldDto> Fields { get; set; } = [];
    [Parameter] public IReadOnlyList<TaskDto>? Tasks { get; set; }
    [Parameter] public IReadOnlyList<ProjectPickerDto> Projects { get; set; } = [];
    [Parameter] public TimeEntryDto? Entry { get; set; }
    [Parameter] public bool RequireTime { get; set; } = true;

    /// <summary>For a new entry, pre-link this task (e.g. "log time" from the Tasks page).</summary>
    [Parameter] public int? InitialTaskId { get; set; }

    private TimeEntryModel model = new();
    private TimeEntryFields entryFields = default!;
    private bool saving;
    private string? error;

    protected override void OnInitialized()
    {
        if (Entry is { } e)
        {
            model = new TimeEntryModel
            {
                Note = e.Note,
                EntryDate = e.EntryDate,
                StartTime = e.StartTime,
                DurationMinutes = e.DurationMinutes,
                TaskId = e.TaskId,
                ProjectId = e.ProjectId,
                Attributes = e.Attributes.ToDictionary(a => a.FieldId, a => a.Value),
            };
        }
        else if (InitialTaskId is { } taskId)
        {
            model.TaskId = taskId;
            // Mirror TimeEntryFields.OnTaskChanged: pre-link from "Log time from task" should
            // also carry the task's first-class project into the entry.
            var task = Tasks?.FirstOrDefault(t => t.Id == taskId);
            if (task?.ProjectId is { } pid)
            {
                model.ProjectId = pid;
            }
        }
    }

    private async Task SaveAsync()
    {
        error = Validate();
        if (error is not null)
        {
            return;
        }

        saving = true;
        try
        {
            var request = ToRequest();
            var result = Entry is null
                ? await Api.CreateTimeEntryAsync(OrgId, request)
                : await Api.UpdateTimeEntryAsync(OrgId, Entry.Id, request);

            if (result.Success)
            {
                // Persist any task progress adjustment made alongside the entry.
                await entryFields.PersistTaskProgressAsync();
                Snackbar.Add(Entry is null ? "Entry added" : "Entry updated", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                error = result.Error;
            }
        }
        finally
        {
            saving = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (Entry is null)
        {
            return;
        }

        if (!await JS.InvokeAsync<bool>("confirm", "Delete this time entry?"))
        {
            return;
        }

        saving = true;
        try
        {
            var result = await Api.DeleteTimeEntryAsync(OrgId, Entry.Id);
            if (result.Success)
            {
                Snackbar.Add("Entry deleted", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                error = result.Error;
            }
        }
        finally
        {
            saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(model.Note))
        {
            return "A note is required.";
        }

        // New entries must be complete; an existing entry may be saved partially and
        // simply stays flagged incomplete until the required fields are filled.
        if (Entry is null && MissingRequired() is { Count: > 0 } missing)
        {
            return $"Required: {string.Join(", ", missing)}";
        }

        return null;
    }

    private List<string> MissingRequired() => Fields
        .Where(f => f.IsRequired &&
            string.IsNullOrWhiteSpace(model.Attributes.TryGetValue(f.Id, out var v) ? v : null))
        .Select(f => f.Label)
        .ToList();

    private CreateTimeEntryRequest ToRequest() => new()
    {
        Note = model.Note,
        EntryDate = model.EntryDate,
        StartTime = model.StartTime,
        DurationMinutes = model.DurationMinutes,
        TaskId = model.TaskId,
        ProjectId = model.ProjectId,
        Attributes = new Dictionary<int, string?>(model.Attributes),
    };
}
