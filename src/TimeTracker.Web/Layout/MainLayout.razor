@inherits LayoutComponentBase
@using TimeTracker.Contracts.Me
@using TimeTracker.Web.Services
@using TimeTracker.Web.Theme
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject TimeTrackerApi Api

<MudThemeProvider @ref="_themeProvider" @bind-IsDarkMode="_isDarkMode" Theme="AppTheme.Instance" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@*  Cascade the fetched MeDto so any descendant component can pick it up instead of
    re-fetching /api/me on its own. Existing pages that still call Api.GetMeAsync()
    keep working unchanged; they can migrate to the cascading value over time. *@
<CascadingValue Value="_me" Name="Me">
<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudIcon Icon="@Icons.Material.Filled.AccessTimeFilled" Class="mr-2" />
        <MudText Typo="Typo.h6">TimeTracker</MudText>
        <MudSpacer />
        <MudTooltip Text="My profile">
            <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Href="me" />
        </MudTooltip>
        <MudTooltip Text="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")">
            <MudIconButton Icon="@DarkModeIcon" Color="Color.Inherit" OnClick="@ToggleDarkMode" />
        </MudTooltip>
        @* Only render the sign-out chip when MSAL is actually configured — otherwise the
           dev backdoor is in play and there's no session to clear. *@
        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="Sign out">
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="SignOut" />
                </MudTooltip>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always" Variant="@DrawerVariant.Responsive">
        <MudNavMenu>
            @* Top-level: every signed-in user can log time, view tasks, import calendar. *@
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Schedule">Log Time</MudNavLink>
            <MudNavLink Href="tasks" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Checklist">Tasks</MudNavLink>
            <MudNavLink Href="import" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CalendarMonth">Import from Outlook</MudNavLink>

            @* Administration group hides entirely if the user holds no admin right in
               any org AND isn't a global admin. Otherwise each link is gated on a
               specific right (matching the API's HasRightAsync check on the corresponding
               endpoints). Until /api/me has been fetched, _me is null and we hide
               everything to avoid a flash of admin items the user doesn't actually have. *@
            @if (_me is not null && (_me.IsGlobalAdmin || HasAnyAdminRight()))
            {
                <MudNavGroup Title="Administration" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="true">
                    @if (_me.IsGlobalAdmin)
                    {
                        <MudNavLink Href="admin/organizations" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Public">Global Admin</MudNavLink>
                    }
                    @if (HasRightInAnyOrg("ManageOrganization"))
                    {
                        <MudNavLink Href="admin/organization" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Business">Organization</MudNavLink>
                    }
                    @if (HasRightInAnyOrg("ManageProjects"))
                    {
                        <MudNavLink Href="admin/projects" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.WorkOutline">Projects</MudNavLink>
                    }
                    @if (HasRightInAnyOrg("ManageUsers"))
                    {
                        <MudNavLink Href="admin/users" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">Users</MudNavLink>
                    }
                    @if (HasRightInAnyOrg("ManageRoles"))
                    {
                        <MudNavLink Href="admin/roles" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Badge">Roles</MudNavLink>
                    }
                    @if (HasRightInAnyOrg("ManageFields"))
                    {
                        <MudNavLink Href="admin" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Tune">Fields</MudNavLink>
                    }
                </MudNavGroup>
            }
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-6">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent>
                    <MudAlert Severity="Severity.Error" Class="my-4">
                        <MudText Typo="Typo.subtitle1">Something went wrong on this page.</MudText>
                        <MudText Typo="Typo.body2" Class="mb-2">Try reloading. If it keeps happening, the API may be down.</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Refresh" OnClick="Reload">Reload</MudButton>
                    </MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>
</CascadingValue>

@code {
    private MudThemeProvider _themeProvider = default!;
    private ErrorBoundary _errorBoundary = default!;
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _prefsLoaded;
    private MeDto? _me;

    // Clear the boundary on navigation so a previous page's error doesn't stick.
    protected override void OnParametersSet() => _errorBoundary?.Recover();

    private void Reload() => Nav.NavigateTo(Nav.Uri, forceLoad: true);

    private string DarkModeIcon =>
        _isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _prefsLoaded)
        {
            return;
        }
        _prefsLoaded = true;

        // Single /api/me fetch that drives dark-mode preference AND nav-hiding.
        // Cascaded down so children don't have to re-fetch.
        try
        {
            _me = await Api.GetMeAsync();
            _isDarkMode = _me?.DarkMode ?? await _themeProvider.GetSystemDarkModeAsync();
        }
        catch
        {
            // Auth not yet established or the API is down — fall back to OS dark mode
            // and leave the nav fully hidden until a retry succeeds.
            _isDarkMode = await _themeProvider.GetSystemDarkModeAsync();
        }
        StateHasChanged();
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    // MSAL takes the user to Entra's logout endpoint, then back to /authentication/logout-callback.
    private void SignOut() => Nav.NavigateToLogout("authentication/logout");

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        // Persist server-side so the choice follows the user. Failure is silent — the local
        // toggle still applies for this session.
        try
        {
            await Api.SaveMePreferencesAsync(new SaveMePreferencesRequest { DarkMode = _isDarkMode });
        }
        catch { /* best-effort */ }
    }

    /// <summary>True if the user holds the given right (by enum name) in ANY org they belong to.</summary>
    private bool HasRightInAnyOrg(string rightName) =>
        _me is not null && _me.OrgRights.Values.Any(rights => rights.Contains(rightName));

    /// <summary>True if the user holds ANY admin-class right in any org. Drives the
    /// Administration group's overall visibility so signed-in users with zero admin
    /// access don't even see the group header.</summary>
    private bool HasAnyAdminRight() =>
        HasRightInAnyOrg("ManageOrganization")
        || HasRightInAnyOrg("ManageProjects")
        || HasRightInAnyOrg("ManageUsers")
        || HasRightInAnyOrg("ManageRoles")
        || HasRightInAnyOrg("ManageFields");
}
