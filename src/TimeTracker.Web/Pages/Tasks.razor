@page "/tasks"
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Contracts.Tasks
@using TimeTracker.Web.Services
@inject TimeTracker.Web.Services.TimeTrackerApi Api
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Tasks</PageTitle>

@if (loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        <div class="d-flex align-center justify-space-between" style="gap:1rem">
            <span>@loadError</span>
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadAllAsync">Retry</MudButton>
        </div>
    </MudAlert>
}

@if (organizations is null)
{
    @if (loadError is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
}
else if (organizations.Count == 0)
{
    <MudAlert Severity="Severity.Warning">No organizations available for your account.</MudAlert>
}
else
{
    <MudSelect T="int" Label="Organization" Value="selectedOrgId" ValueChanged="OnOrgChanged"
               Variant="Variant.Outlined" Class="mb-4" Style="max-width:420px">
        @foreach (var org in organizations)
        {
            <MudSelectItem T="int" Value="@org.Id">
                @org.Name@(org.RoleName is null ? "" : $" — {org.RoleName}")
            </MudSelectItem>
        }
    </MudSelect>

    <div class="d-flex justify-space-between align-center mb-3">
        <MudText Typo="Typo.h5">My tasks</MudText>
        @if (!showEditor)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="NewTask">Add task</MudButton>
        }
    </div>

    @if (showEditor && editing is not null)
    {
        <MudCard Class="mb-4" Elevation="2">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-2">@(editing.Id == 0 ? "New task" : "Edit task")</MudText>
                <MudTextField T="string" Label="Title" @bind-Value="editing.Title" Required="true"
                              Variant="Variant.Outlined" Class="mb-3" />
                <MudTextField T="string" Label="Description" @bind-Value="editing.Description" Lines="2"
                              AutoGrow="true" MaxLines="12" Variant="Variant.Outlined" Class="mb-3" />
                <MudCheckBox T="bool" Label="Complete" @bind-Value="editing.IsComplete" />
                @if (errorMessage is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@errorMessage</MudAlert>
                }
            </MudCardContent>
            <MudCardActions>
                <MudSpacer />
                <MudButton OnClick="CancelEdit">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="saving">
                    @(saving ? "Saving…" : "Save task")
                </MudButton>
            </MudCardActions>
        </MudCard>
    }

    @if (tasks is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (tasks.Count == 0)
    {
        <MudText Class="mud-text-secondary">No tasks yet. Add one to track work you need to do.</MudText>
    }
    else
    {
        <MudTable Items="tasks" Hover="true" Dense="true" Elevation="1">
            <HeaderContent>
                <MudTh Style="width:1px">Done</MudTh>
                <MudTh>Task</MudTh>
                <MudTh Style="width:1px"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudCheckBox T="bool" Value="@context.IsComplete"
                                 ValueChanged="@(_ => ToggleCompleteAsync(context))" />
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body1"
                             Style="@(context.IsComplete ? "text-decoration:line-through" : "")">
                        <b>@context.Title</b>
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(context.Description))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Description</MudText>
                    }
                </MudTd>
                <MudTd Style="text-align:right; white-space:nowrap">
                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => EditTask(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => DeleteAsync(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    private IReadOnlyList<OrganizationDto>? organizations;
    private IReadOnlyList<TaskDto>? tasks;
    private int selectedOrgId;

    private TaskEditModel? editing;
    private bool showEditor;
    private bool saving;
    private string? errorMessage;
    private string? loadError;

    protected override Task OnInitializedAsync() => ReloadAllAsync();

    private Task ReloadAllAsync() => GuardAsync(async () =>
    {
        organizations = await Api.GetOrganizationsAsync();
        if (organizations.Count > 0)
        {
            if (selectedOrgId == 0)
            {
                selectedOrgId = organizations[0].Id;
            }
            await LoadAsync();
        }
    });

    private async Task OnOrgChanged(int orgId)
    {
        selectedOrgId = orgId;
        CancelEdit();
        await GuardAsync(LoadAsync);
    }

    private async Task LoadAsync() => tasks = await Api.GetTasksAsync(selectedOrgId);

    private async Task GuardAsync(Func<Task> action)
    {
        try
        {
            loadError = null;
            await action();
        }
        catch (ApiException ex)
        {
            loadError = ex.Message;
        }
        catch (Exception)
        {
            loadError = "Something went wrong loading your tasks. Please retry.";
        }
    }

    private void NewTask()
    {
        editing = new TaskEditModel();
        errorMessage = null;
        showEditor = true;
    }

    private void EditTask(TaskDto task)
    {
        editing = new TaskEditModel
        {
            Id = task.Id,
            Title = task.Title,
            Description = task.Description,
            IsComplete = task.IsComplete,
        };
        errorMessage = null;
        showEditor = true;
    }

    private void CancelEdit()
    {
        showEditor = false;
        editing = null;
        errorMessage = null;
    }

    private async Task SaveAsync()
    {
        if (editing is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(editing.Title))
        {
            errorMessage = "A title is required.";
            return;
        }

        saving = true;
        try
        {
            var request = new SaveTaskRequest
            {
                Title = editing.Title,
                Description = editing.Description,
                IsComplete = editing.IsComplete,
            };

            var result = editing.Id == 0
                ? await Api.CreateTaskAsync(selectedOrgId, request)
                : await Api.UpdateTaskAsync(selectedOrgId, editing.Id, request);

            if (result.Success)
            {
                Snackbar.Add(editing.Id == 0 ? "Task added" : "Task updated", Severity.Success);
                CancelEdit();
                await LoadAsync();
            }
            else
            {
                errorMessage = result.Error;
            }
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ToggleCompleteAsync(TaskDto task)
    {
        var request = new SaveTaskRequest
        {
            Title = task.Title,
            Description = task.Description,
            IsComplete = !task.IsComplete,
        };
        await Api.UpdateTaskAsync(selectedOrgId, task.Id, request);
        await LoadAsync();
    }

    private async Task DeleteAsync(TaskDto task)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete the task \"{task.Title}\"?"))
        {
            return;
        }

        await Api.DeleteTaskAsync(selectedOrgId, task.Id);
        Snackbar.Add("Task deleted", Severity.Success);
        await LoadAsync();
    }

    private sealed class TaskEditModel
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsComplete { get; set; }
    }
}
