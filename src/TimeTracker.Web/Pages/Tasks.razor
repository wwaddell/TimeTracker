@page "/tasks"
@using TimeTracker.Contracts.Me
@using TimeTracker.Contracts.Members
@using TimeTracker.Contracts.Projects
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Contracts.Tasks
@using TimeTracker.Domain.Enums
@using TimeTracker.Web.Components
@using TimeTracker.Web.Services
@inject TimeTrackerApi Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>Tasks</PageTitle>

@if (loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        <div class="d-flex align-center justify-space-between" style="gap:1rem">
            <span>@loadError</span>
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadAllAsync">Retry</MudButton>
        </div>
    </MudAlert>
}

@if (organizations is null)
{
    @if (loadError is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
}
else if (organizations.Count == 0)
{
    <MudAlert Severity="Severity.Warning">No organizations available for your account.</MudAlert>
}
else
{
    @* Hide the org switcher when the user only belongs to one org, or has opted to hide it. *@
    @if (organizations.Count > 1 && me?.HideOrgSwitcher != true)
    {
        <MudSelect T="int" Label="Organization" Value="selectedOrgId" ValueChanged="OnOrgChanged"
                   Variant="Variant.Outlined" Class="mb-4" Style="max-width:420px">
            @foreach (var org in organizations)
            {
                <MudSelectItem T="int" Value="@org.Id">
                    @org.Name@(org.RoleName is null ? "" : $" — {org.RoleName}")
                </MudSelectItem>
            }
        </MudSelect>
    }

    @* No page title — the nav highlights "Tasks" and the columns headers narrate. *@
    <div class="d-flex justify-end align-center mb-3 flex-wrap" style="gap:1rem">
        <div class="d-flex align-center flex-wrap" style="gap:.75rem">
            <MudSelect T="string" Value="scope" ValueChanged="OnScopeChanged" Dense="true"
                       Margin="Margin.Dense" Variant="Variant.Outlined" Label="Show" Style="min-width:200px">
                <MudSelectItem T="string" Value="@("mine")">Assigned to me</MudSelectItem>
                <MudSelectItem T="string" Value="@("assigned-by-me")">I assigned to others</MudSelectItem>
                <MudSelectItem T="string" Value="@("all")">All I'm involved in</MudSelectItem>
            </MudSelect>
            <MudTextField T="string" @bind-Value="search" Immediate="true" Clearable="true"
                          Placeholder="Search tasks…" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" Margin="Margin.Dense"
                          Variant="Variant.Outlined" Style="min-width:220px" />
            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                <MudButton Variant="@(showAll ? Variant.Outlined : Variant.Filled)"
                           Color="@(showAll ? Color.Default : Color.Primary)" OnClick="@(() => showAll = false)">Active</MudButton>
                <MudButton Variant="@(showAll ? Variant.Filled : Variant.Outlined)"
                           Color="@(showAll ? Color.Primary : Color.Default)" OnClick="@(() => showAll = true)">All</MudButton>
            </MudButtonGroup>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => OpenDialogAsync(null))">Add task</MudButton>
        </div>
    </div>

    @if (tasks is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (tasks.Count == 0)
    {
        <MudText Class="mud-text-secondary">No tasks yet. Add one to track work you need to do.</MudText>
    }
    else
    {
        @* Outlook-style list: columnar first line, description wraps under the full row. *@
        <MudPaper Elevation="1" Class="tt-tasks">
            <div class="tt-tasks__head">
                <div class="tt-col tt-col--pri">
                    <MudLink Color="Color.Inherit" Typo="Typo.caption" Underline="Underline.None"
                             OnClick="@(() => ToggleSort(SortKey.Priority))">
                        <span class="d-inline-flex align-center" style="gap:.15rem">!@SortGlyph(SortKey.Priority)</span>
                    </MudLink>
                </div>
                <div class="tt-col tt-col--title">
                    <MudLink Color="Color.Inherit" Typo="Typo.caption" Underline="Underline.None"
                             OnClick="@(() => ToggleSort(SortKey.Title))">Task@(SortGlyph(SortKey.Title))</MudLink>
                </div>
                <div class="tt-col tt-col--assignee">
                    <MudLink Color="Color.Inherit" Typo="Typo.caption" Underline="Underline.None"
                             OnClick="@(() => ToggleSort(SortKey.Assignee))">Assignee@(SortGlyph(SortKey.Assignee))</MudLink>
                </div>
                <div class="tt-col tt-col--project">
                    <MudLink Color="Color.Inherit" Typo="Typo.caption" Underline="Underline.None"
                             OnClick="@(() => ToggleSort(SortKey.Project))">Project@(SortGlyph(SortKey.Project))</MudLink>
                </div>
                <div class="tt-col tt-col--due">
                    <MudLink Color="Color.Inherit" Typo="Typo.caption" Underline="Underline.None"
                             OnClick="@(() => ToggleSort(SortKey.Due))">Due@(SortGlyph(SortKey.Due))</MudLink>
                </div>
                <div class="tt-col tt-col--est">
                    <MudLink Color="Color.Inherit" Typo="Typo.caption" Underline="Underline.None"
                             OnClick="@(() => ToggleSort(SortKey.Estimate))">Est.@(SortGlyph(SortKey.Estimate))</MudLink>
                </div>
                <div class="tt-col tt-col--progress">
                    <MudLink Color="Color.Inherit" Typo="Typo.caption" Underline="Underline.None"
                             OnClick="@(() => ToggleSort(SortKey.Progress))">Progress@(SortGlyph(SortKey.Progress))</MudLink>
                </div>
                <div class="tt-col tt-col--actions"></div>
            </div>
            @if (!Sorted.Any())
            {
                <div class="tt-tasks__empty">
                    <MudText Class="mud-text-secondary">No tasks match the current search/filter.</MudText>
                </div>
            }
            else
            {
                @foreach (var t in Sorted)
                {
                    <div class="tt-tasks__row" @key="t.Id">
                        <div class="tt-tasks__line">
                            <div class="tt-col tt-col--pri">
                                @if (t.Priority is { } p)
                                {
                                    <MudTooltip Text="@($"{p} priority")">
                                        <MudIcon Icon="@PriorityIcon(p)" Color="@PriorityColor(p)" Size="Size.Small" />
                                    </MudTooltip>
                                }
                            </div>
                            <div class="tt-col tt-col--title">
                                <div class="d-flex align-center" style="gap:.4rem; flex-wrap:wrap; min-width:0">
                                    <MudText Typo="Typo.body1" Class="tt-tasks__title"
                                             Style="@(t.IsComplete ? "text-decoration:line-through" : "")">
                                        <b>@t.Title</b>
                                    </MudText>
                                    @if (!string.IsNullOrWhiteSpace(t.ReferenceCode))
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@t.ReferenceCode</MudChip>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(t.ExternalUrl))
                                    {
                                        <MudTooltip Text="@t.ExternalUrl">
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                                                           Href="@t.ExternalUrl" Target="_blank" />
                                        </MudTooltip>
                                    }
                                </div>
                            </div>
                            <div class="tt-col tt-col--assignee">
                                @if (me is not null && t.AssignedToUserId == me.Id)
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Me</MudText>
                                }
                                else
                                {
                                    <MudTooltip Text="@($"Assigned to {t.AssignedToName}")">
                                        <span class="d-inline-flex align-center" style="gap:.25rem; min-width:0">
                                            <MudIcon Icon="@Icons.Material.Filled.PersonOutline" Size="Size.Small" Color="Color.Info" />
                                            <MudText Typo="Typo.body2" Class="tt-tasks__ellipsis">@t.AssignedToName</MudText>
                                        </span>
                                    </MudTooltip>
                                }
                            </div>
                            <div class="tt-col tt-col--project">
                                @if (!string.IsNullOrWhiteSpace(t.ProjectName))
                                {
                                    <span class="d-inline-flex align-center" style="gap:.25rem; min-width:0">
                                        <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Color="Color.Primary" />
                                        <MudText Typo="Typo.body2" Class="tt-tasks__ellipsis">@t.ProjectName</MudText>
                                    </span>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">—</MudText>
                                }
                            </div>
                            <div class="tt-col tt-col--due">
                                @if (t.DueDate is { } d)
                                {
                                    <MudText Typo="Typo.body2" Color="@(IsOverdue(d, t.IsComplete) ? Color.Error : Color.Inherit)">
                                        @d.ToString("MMM d")
                                    </MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">—</MudText>
                                }
                            </div>
                            <div class="tt-col tt-col--est">
                                <MudText Typo="Typo.body2">@(t.EstimatedHours is { } h ? $"{h:0.##} h" : "—")</MudText>
                            </div>
                            <div class="tt-col tt-col--progress">
                                <div class="d-flex align-center" style="gap:.5rem">
                                    <MudProgressLinear Color="Color.Primary" Rounded="true" Value="@t.PercentComplete"
                                                       Style="height:8px; flex:1" />
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@t.PercentComplete%</MudText>
                                </div>
                            </div>
                            <div class="tt-col tt-col--actions">
                                <MudTooltip Text="Log time">
                                    <MudIconButton Icon="@Icons.Material.Filled.MoreTime" Color="Color.Primary" Size="Size.Small"
                                                   OnClick="@(() => LogTimeAsync(t))" />
                                </MudTooltip>
                                <MudTooltip Text="Edit">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                   OnClick="@(() => OpenDialogAsync(t))" />
                                </MudTooltip>
                                <MudTooltip Text="Delete">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => DeleteAsync(t))" />
                                </MudTooltip>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(t.Description))
                        {
                            @* Wraps across the full row width, indented under the priority column to align with the title. *@
                            <div class="tt-tasks__preview">@t.Description</div>
                        }
                    </div>
                }
            }
        </MudPaper>
    }
}

@code {
    private IReadOnlyList<OrganizationDto>? organizations;
    private MeDto? me;
    private IReadOnlyList<TaskDto>? tasks;
    private IReadOnlyList<EntryFieldDto>? fields;
    private IReadOnlyList<ProjectPickerDto>? projects;
    private IReadOnlyList<MemberDto>? members;
    private int selectedOrgId;
    private string? loadError;

    private string? search;
    private bool showAll; // false = active only (default)
    private string scope = "mine"; // "mine" | "assigned-by-me" | "all"

    // Outlook-style list sort: click a header to toggle direction; clicking a new key resets to descending
    // for priority/progress and ascending for everything else (matches what people usually want).
    private enum SortKey { Priority, Title, Assignee, Project, Due, Estimate, Progress }
    private SortKey sortKey = SortKey.Priority;
    private bool sortDesc = true;

    private void ToggleSort(SortKey key)
    {
        if (sortKey == key)
        {
            sortDesc = !sortDesc;
        }
        else
        {
            sortKey = key;
            sortDesc = key is SortKey.Priority or SortKey.Progress or SortKey.Estimate;
        }
    }

    private string SortGlyph(SortKey key) =>
        sortKey == key ? (sortDesc ? " ▾" : " ▴") : string.Empty;

    private async Task OnScopeChanged(string value)
    {
        scope = value;
        await GuardAsync(LoadAsync);
    }

    private bool OrgRequiresTime =>
        organizations?.FirstOrDefault(o => o.Id == selectedOrgId)?.RequireTime ?? true;

    // Active-only + search filter, applied client-side over the loaded list.
    private IEnumerable<TaskDto> Filtered => (tasks ?? Enumerable.Empty<TaskDto>())
        .Where(t => showAll || !t.IsComplete)
        .Where(t => string.IsNullOrWhiteSpace(search)
            || t.Title.Contains(search!, StringComparison.OrdinalIgnoreCase)
            || (t.Description?.Contains(search!, StringComparison.OrdinalIgnoreCase) ?? false));

    // Filtered + sorted by the current header. Completed tasks always sink to the bottom so the
    // active work stays on top regardless of which column the user sorts by.
    private IEnumerable<TaskDto> Sorted
    {
        get
        {
            var ordered = Filtered.OrderBy(t => t.IsComplete);
            return sortKey switch
            {
                SortKey.Priority => sortDesc
                    ? ordered.ThenByDescending(t => (int)(t.Priority ?? 0)).ThenByDescending(t => t.Id)
                    : ordered.ThenBy(t => (int)(t.Priority ?? 0)).ThenByDescending(t => t.Id),
                SortKey.Title => sortDesc
                    ? ordered.ThenByDescending(t => t.Title)
                    : ordered.ThenBy(t => t.Title),
                SortKey.Assignee => sortDesc
                    ? ordered.ThenByDescending(t => t.AssignedToName)
                    : ordered.ThenBy(t => t.AssignedToName),
                SortKey.Project => sortDesc
                    ? ordered.ThenByDescending(t => t.ProjectName ?? "")
                    : ordered.ThenBy(t => t.ProjectName ?? ""),
                SortKey.Due => sortDesc
                    ? ordered.ThenByDescending(t => t.DueDate ?? DateOnly.MinValue)
                    : ordered.ThenBy(t => t.DueDate ?? DateOnly.MaxValue),
                SortKey.Estimate => sortDesc
                    ? ordered.ThenByDescending(t => t.EstimatedHours ?? -1m)
                    : ordered.ThenBy(t => t.EstimatedHours ?? decimal.MaxValue),
                SortKey.Progress => sortDesc
                    ? ordered.ThenByDescending(t => t.PercentComplete)
                    : ordered.ThenBy(t => t.PercentComplete),
                _ => ordered,
            };
        }
    }

    protected override Task OnInitializedAsync() => ReloadAllAsync();

    private Task ReloadAllAsync() => GuardAsync(async () =>
    {
        organizations = await Api.GetOrganizationsAsync();
        me ??= await Api.GetMeAsync(); // for HideOrgSwitcher preference
        if (organizations.Count > 0)
        {
            if (selectedOrgId == 0)
            {
                selectedOrgId = organizations[0].Id;
            }
            await LoadAsync();
        }
    });

    private async Task OnOrgChanged(int orgId)
    {
        selectedOrgId = orgId;
        await GuardAsync(LoadAsync);
    }

    private async Task LoadAsync()
    {
        tasks = await Api.GetTasksAsync(selectedOrgId, scope);
        fields = await Api.GetEntryFieldsAsync(selectedOrgId);
        projects = await Api.GetVisibleProjectsAsync(selectedOrgId);
        // Members feed the assignee picker. Falls back to "just me" if the user lacks
        // ManageUsers (a future endpoint should expose a member roster to any member).
        try
        {
            members = await Api.GetMembersAsync(selectedOrgId);
        }
        catch
        {
            members = me is null
                ? []
                : [new MemberDto(me.Id, me.Email, me.DisplayName, false, true, [])];
        }
    }

    private async Task OpenDialogAsync(TaskDto? task)
    {
        var parameters = new DialogParameters<TaskDialog>
        {
            { x => x.OrgId, selectedOrgId },
            { x => x.Existing, task },
            { x => x.Projects, projects ?? [] },
            { x => x.Members, members ?? [] },
            { x => x.CurrentUserId, me?.Id ?? 0 },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<TaskDialog>(task is null ? "New task" : "Edit task", parameters, options);
        if (await dialog.Result is { Canceled: false })
        {
            await LoadAsync();
        }
    }

    // Log time against a task: opens the shared entry dialog with the task pre-linked.
    private async Task LogTimeAsync(TaskDto task)
    {
        var parameters = new DialogParameters<TimeEntryDialog>
        {
            { x => x.OrgId, selectedOrgId },
            { x => x.Fields, fields ?? [] },
            { x => x.Tasks, tasks },
            { x => x.Projects, projects ?? [] },
            { x => x.Entry, (TimeEntryDto?)null },
            { x => x.RequireTime, OrgRequiresTime },
            { x => x.InitialTaskId, (int?)task.Id },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<TimeEntryDialog>($"Log time — {task.Title}", parameters, options);
        if (await dialog.Result is { Canceled: false })
        {
            await LoadAsync(); // progress may have changed via the entry's task-progress control
        }
    }

    private async Task DeleteAsync(TaskDto task)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete the task \"{task.Title}\"?"))
        {
            return;
        }

        await Api.DeleteTaskAsync(selectedOrgId, task.Id);
        Snackbar.Add("Task deleted", Severity.Success);
        await LoadAsync();
    }

    private static string PriorityIcon(TaskPriority p) => p switch
    {
        TaskPriority.Urgent => Icons.Material.Filled.PriorityHigh,
        TaskPriority.High => Icons.Material.Filled.KeyboardArrowUp,
        TaskPriority.Medium => Icons.Material.Filled.DragHandle,
        _ => Icons.Material.Filled.KeyboardArrowDown,
    };

    private static Color PriorityColor(TaskPriority p) => p switch
    {
        TaskPriority.Urgent => Color.Error,
        TaskPriority.High => Color.Warning,
        TaskPriority.Medium => Color.Info,
        _ => Color.Default,
    };

    private static bool IsOverdue(DateOnly due, bool isComplete) =>
        !isComplete && due < DateOnly.FromDateTime(DateTime.Today);

    private async Task GuardAsync(Func<Task> action)
    {
        try
        {
            loadError = null;
            await action();
        }
        catch (ApiException ex)
        {
            loadError = ex.Message;
        }
        catch (Exception)
        {
            loadError = "Something went wrong loading your tasks. Please retry.";
        }
    }
}
