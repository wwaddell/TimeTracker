@page "/tasks"
@using TimeTracker.Contracts.Me
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Contracts.Tasks
@using TimeTracker.Domain.Enums
@using TimeTracker.Web.Components
@using TimeTracker.Web.Services
@inject TimeTrackerApi Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>Tasks</PageTitle>

@if (loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        <div class="d-flex align-center justify-space-between" style="gap:1rem">
            <span>@loadError</span>
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadAllAsync">Retry</MudButton>
        </div>
    </MudAlert>
}

@if (organizations is null)
{
    @if (loadError is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
}
else if (organizations.Count == 0)
{
    <MudAlert Severity="Severity.Warning">No organizations available for your account.</MudAlert>
}
else
{
    @* Hide the org switcher when the user only belongs to one org, or has opted to hide it. *@
    @if (organizations.Count > 1 && me?.HideOrgSwitcher != true)
    {
        <MudSelect T="int" Label="Organization" Value="selectedOrgId" ValueChanged="OnOrgChanged"
                   Variant="Variant.Outlined" Class="mb-4" Style="max-width:420px">
            @foreach (var org in organizations)
            {
                <MudSelectItem T="int" Value="@org.Id">
                    @org.Name@(org.RoleName is null ? "" : $" — {org.RoleName}")
                </MudSelectItem>
            }
        </MudSelect>
    }

    <div class="d-flex justify-space-between align-center mb-3 flex-wrap" style="gap:1rem">
        <MudText Typo="Typo.h5">My tasks</MudText>
        <div class="d-flex align-center flex-wrap" style="gap:.75rem">
            <MudTextField T="string" @bind-Value="search" Immediate="true" Clearable="true"
                          Placeholder="Search tasks…" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" Margin="Margin.Dense"
                          Variant="Variant.Outlined" Style="min-width:220px" />
            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                <MudButton Variant="@(showAll ? Variant.Outlined : Variant.Filled)"
                           Color="@(showAll ? Color.Default : Color.Primary)" OnClick="@(() => showAll = false)">Active</MudButton>
                <MudButton Variant="@(showAll ? Variant.Filled : Variant.Outlined)"
                           Color="@(showAll ? Color.Primary : Color.Default)" OnClick="@(() => showAll = true)">All</MudButton>
            </MudButtonGroup>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => OpenDialogAsync(null))">Add task</MudButton>
        </div>
    </div>

    @if (tasks is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (tasks.Count == 0)
    {
        <MudText Class="mud-text-secondary">No tasks yet. Add one to track work you need to do.</MudText>
    }
    else
    {
        <MudTable Items="Filtered" Hover="true" Dense="true" Elevation="1">
            <HeaderContent>
                <MudTh Style="width:1px; text-align:center">
                    <MudTableSortLabel T="TaskDto" SortBy="@(x => (int)(x.Priority ?? 0))">!</MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel T="TaskDto" SortBy="@(x => x.Title)">Task</MudTableSortLabel>
                </MudTh>
                <MudTh Style="width:1px; white-space:nowrap">
                    <MudTableSortLabel T="TaskDto" SortBy="@(x => x.DueDate ?? DateOnly.MaxValue)">Due</MudTableSortLabel>
                </MudTh>
                <MudTh Style="width:1px; white-space:nowrap">
                    <MudTableSortLabel T="TaskDto" SortBy="@(x => x.EstimatedHours ?? -1m)">Est.</MudTableSortLabel>
                </MudTh>
                <MudTh Style="width:160px">
                    <MudTableSortLabel T="TaskDto" SortBy="@(x => x.PercentComplete)">Progress</MudTableSortLabel>
                </MudTh>
                <MudTh Style="width:1px"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="text-align:center">
                    @if (context.Priority is { } p)
                    {
                        <MudTooltip Text="@($"{p} priority")">
                            <MudIcon Icon="@PriorityIcon(p)" Color="@PriorityColor(p)" Size="Size.Small" />
                        </MudTooltip>
                    }
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body1"
                             Style="@(context.IsComplete ? "text-decoration:line-through" : "")">
                        <b>@context.Title</b>
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(context.Description))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Description</MudText>
                    }
                </MudTd>
                <MudTd Style="white-space:nowrap">
                    @if (context.DueDate is { } d)
                    {
                        <MudText Typo="Typo.body2" Color="@(IsOverdue(d, context.IsComplete) ? Color.Error : Color.Inherit)">
                            @d.ToString("MMM d")
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">—</MudText>
                    }
                </MudTd>
                <MudTd Style="white-space:nowrap">
                    @(context.EstimatedHours is { } h ? $"{h:0.##} h" : "—")
                </MudTd>
                <MudTd>
                    <div class="d-flex align-center" style="gap:.5rem">
                        <MudProgressLinear Color="Color.Primary" Rounded="true" Value="@context.PercentComplete"
                                           Style="height:8px; flex:1" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.PercentComplete%</MudText>
                    </div>
                </MudTd>
                <MudTd Style="text-align:right; white-space:nowrap">
                    <MudTooltip Text="Log time">
                        <MudIconButton Icon="@Icons.Material.Filled.MoreTime" Color="Color.Primary" Size="Size.Small"
                                       OnClick="@(() => LogTimeAsync(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => OpenDialogAsync(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => DeleteAsync(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="mud-text-secondary">No tasks match the current search/filter.</MudText>
            </NoRecordsContent>
        </MudTable>
    }
}

@code {
    private IReadOnlyList<OrganizationDto>? organizations;
    private MeDto? me;
    private IReadOnlyList<TaskDto>? tasks;
    private IReadOnlyList<EntryFieldDto>? fields;
    private int selectedOrgId;
    private string? loadError;

    private string? search;
    private bool showAll; // false = active only (default)

    private bool OrgRequiresTime =>
        organizations?.FirstOrDefault(o => o.Id == selectedOrgId)?.RequireTime ?? true;

    // Active-only + search filter, applied client-side over the loaded list.
    private IEnumerable<TaskDto> Filtered => (tasks ?? Enumerable.Empty<TaskDto>())
        .Where(t => showAll || !t.IsComplete)
        .Where(t => string.IsNullOrWhiteSpace(search)
            || t.Title.Contains(search!, StringComparison.OrdinalIgnoreCase)
            || (t.Description?.Contains(search!, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override Task OnInitializedAsync() => ReloadAllAsync();

    private Task ReloadAllAsync() => GuardAsync(async () =>
    {
        organizations = await Api.GetOrganizationsAsync();
        me ??= await Api.GetMeAsync(); // for HideOrgSwitcher preference
        if (organizations.Count > 0)
        {
            if (selectedOrgId == 0)
            {
                selectedOrgId = organizations[0].Id;
            }
            await LoadAsync();
        }
    });

    private async Task OnOrgChanged(int orgId)
    {
        selectedOrgId = orgId;
        await GuardAsync(LoadAsync);
    }

    private async Task LoadAsync()
    {
        tasks = await Api.GetTasksAsync(selectedOrgId);
        fields = await Api.GetEntryFieldsAsync(selectedOrgId);
    }

    private async Task OpenDialogAsync(TaskDto? task)
    {
        var parameters = new DialogParameters<TaskDialog>
        {
            { x => x.OrgId, selectedOrgId },
            { x => x.Existing, task },
            { x => x.Fields, fields ?? [] },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<TaskDialog>(task is null ? "New task" : "Edit task", parameters, options);
        if (await dialog.Result is { Canceled: false })
        {
            await LoadAsync();
        }
    }

    // Log time against a task: opens the shared entry dialog with the task pre-linked.
    private async Task LogTimeAsync(TaskDto task)
    {
        var parameters = new DialogParameters<TimeEntryDialog>
        {
            { x => x.OrgId, selectedOrgId },
            { x => x.Fields, fields ?? [] },
            { x => x.Tasks, tasks },
            { x => x.Entry, (TimeEntryDto?)null },
            { x => x.RequireTime, OrgRequiresTime },
            { x => x.InitialTaskId, (int?)task.Id },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<TimeEntryDialog>($"Log time — {task.Title}", parameters, options);
        if (await dialog.Result is { Canceled: false })
        {
            await LoadAsync(); // progress may have changed via the entry's task-progress control
        }
    }

    private async Task DeleteAsync(TaskDto task)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete the task \"{task.Title}\"?"))
        {
            return;
        }

        await Api.DeleteTaskAsync(selectedOrgId, task.Id);
        Snackbar.Add("Task deleted", Severity.Success);
        await LoadAsync();
    }

    private static string PriorityIcon(TaskPriority p) => p switch
    {
        TaskPriority.Urgent => Icons.Material.Filled.PriorityHigh,
        TaskPriority.High => Icons.Material.Filled.KeyboardArrowUp,
        TaskPriority.Medium => Icons.Material.Filled.DragHandle,
        _ => Icons.Material.Filled.KeyboardArrowDown,
    };

    private static Color PriorityColor(TaskPriority p) => p switch
    {
        TaskPriority.Urgent => Color.Error,
        TaskPriority.High => Color.Warning,
        TaskPriority.Medium => Color.Info,
        _ => Color.Default,
    };

    private static bool IsOverdue(DateOnly due, bool isComplete) =>
        !isComplete && due < DateOnly.FromDateTime(DateTime.Today);

    private async Task GuardAsync(Func<Task> action)
    {
        try
        {
            loadError = null;
            await action();
        }
        catch (ApiException ex)
        {
            loadError = ex.Message;
        }
        catch (Exception)
        {
            loadError = "Something went wrong loading your tasks. Please retry.";
        }
    }
}
