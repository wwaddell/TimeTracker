@page "/tasks"
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Contracts.Tasks
@inject TimeTracker.Web.Services.TimeTrackerApi Api
@inject IJSRuntime JS

<PageTitle>Tasks</PageTitle>

@if (organizations is null)
{
    <p><em>Loading…</em></p>
}
else if (organizations.Count == 0)
{
    <div class="alert alert-warning">No organizations available for your account.</div>
}
else
{
    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Organization</label>
            <select class="form-select" @onchange="OnOrgChanged">
                @foreach (var org in organizations)
                {
                    <option value="@org.Id" selected="@(org.Id == selectedOrgId)">
                        @org.Name@(org.RoleName is null ? "" : $" — {org.RoleName}")
                    </option>
                }
            </select>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h4 mb-0">My tasks</h2>
        @if (!showEditor)
        {
            <button class="btn btn-primary btn-sm" @onclick="NewTask">+ Add task</button>
        }
    </div>

    @if (showEditor && editing is not null)
    {
        <div class="card mb-3">
            <div class="card-header">@(editing.Id == 0 ? "New task" : "Edit task")</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Title <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="editing.Title" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="2" @bind="editing.Description"></textarea>
                </div>
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="taskComplete" @bind="editing.IsComplete" />
                    <label class="form-check-label" for="taskComplete">Complete</label>
                </div>
                @if (errorMessage is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0">@errorMessage</div>
                }
            </div>
            <div class="card-footer text-end">
                <button class="btn btn-link" @onclick="CancelEdit">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@saving">
                    @(saving ? "Saving…" : "Save task")
                </button>
            </div>
        </div>
    }

    @if (tasks is null)
    {
        <p><em>Loading…</em></p>
    }
    else if (tasks.Count == 0)
    {
        <p class="text-muted">No tasks yet. Add one to track work you need to do.</p>
    }
    else
    {
        <div class="list-group">
            @foreach (var task in tasks)
            {
                <div class="list-group-item">
                    <div class="d-flex align-items-start">
                        <input type="checkbox" class="form-check-input mt-1 me-2"
                               checked="@task.IsComplete" @onchange="() => ToggleCompleteAsync(task)" />
                        <div class="flex-grow-1">
                            <div class="@(task.IsComplete ? "text-decoration-line-through text-muted" : "")">
                                <strong>@task.Title</strong>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(task.Description))
                            {
                                <div class="small text-muted">@task.Description</div>
                            }
                        </div>
                        <div class="ms-2 text-nowrap">
                            <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => EditTask(task)">Edit</button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteAsync(task)">Delete</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private IReadOnlyList<OrganizationDto>? organizations;
    private IReadOnlyList<TaskDto>? tasks;
    private int selectedOrgId;

    private TaskEditModel? editing;
    private bool showEditor;
    private bool saving;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        organizations = await Api.GetOrganizationsAsync();
        if (organizations.Count > 0)
        {
            selectedOrgId = organizations[0].Id;
            await LoadAsync();
        }
    }

    private async Task OnOrgChanged(ChangeEventArgs e)
    {
        selectedOrgId = int.Parse(e.Value!.ToString()!);
        CancelEdit();
        await LoadAsync();
    }

    private async Task LoadAsync() => tasks = await Api.GetTasksAsync(selectedOrgId);

    private void NewTask()
    {
        editing = new TaskEditModel();
        errorMessage = null;
        showEditor = true;
    }

    private void EditTask(TaskDto task)
    {
        editing = new TaskEditModel
        {
            Id = task.Id,
            Title = task.Title,
            Description = task.Description,
            IsComplete = task.IsComplete,
        };
        errorMessage = null;
        showEditor = true;
    }

    private void CancelEdit()
    {
        showEditor = false;
        editing = null;
        errorMessage = null;
    }

    private async Task SaveAsync()
    {
        if (editing is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(editing.Title))
        {
            errorMessage = "A title is required.";
            return;
        }

        saving = true;
        try
        {
            var request = new SaveTaskRequest
            {
                Title = editing.Title,
                Description = editing.Description,
                IsComplete = editing.IsComplete,
            };

            var result = editing.Id == 0
                ? await Api.CreateTaskAsync(selectedOrgId, request)
                : await Api.UpdateTaskAsync(selectedOrgId, editing.Id, request);

            if (result.Success)
            {
                CancelEdit();
                await LoadAsync();
            }
            else
            {
                errorMessage = result.Error;
            }
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ToggleCompleteAsync(TaskDto task)
    {
        var request = new SaveTaskRequest
        {
            Title = task.Title,
            Description = task.Description,
            IsComplete = !task.IsComplete,
        };
        await Api.UpdateTaskAsync(selectedOrgId, task.Id, request);
        await LoadAsync();
    }

    private async Task DeleteAsync(TaskDto task)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete the task “{task.Title}”?"))
        {
            return;
        }

        await Api.DeleteTaskAsync(selectedOrgId, task.Id);
        await LoadAsync();
    }

    private sealed class TaskEditModel
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsComplete { get; set; }
    }
}
