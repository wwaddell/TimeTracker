@page "/admin"
@using TimeTracker.Contracts.Admin
@using TimeTracker.Contracts.Organizations
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Domain.Enums
@using TimeTracker.Web.Components
@using TimeTracker.Web.Services
@inject TimeTracker.Web.Services.TimeTrackerApi Api
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Manage Fields</PageTitle>

@if (loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        <div class="d-flex align-center justify-space-between" style="gap:1rem">
            <span>@loadError</span>
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadAllAsync">Retry</MudButton>
        </div>
    </MudAlert>
}

@if (organizations is null)
{
    @if (loadError is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
}
else if (organizations.Count == 0)
{
    <MudAlert Severity="Severity.Warning">No organizations available for your account.</MudAlert>
}
else
{
    <MudSelect T="int" Label="Organization" Value="selectedOrgId" ValueChanged="OnOrgChanged"
               Variant="Variant.Outlined" Class="mb-4" Style="max-width:420px">
        @foreach (var org in organizations)
        {
            <MudSelectItem T="int" Value="@org.Id">
                @org.Name@(org.RoleName is null ? "" : $" — {org.RoleName}")
            </MudSelectItem>
        }
    </MudSelect>

    @if (infoMessage is not null)
    {
        <MudAlert Severity="Severity.Info" Class="mb-3" ShowCloseIcon="true"
                  CloseIconClicked="@(() => infoMessage = null)">@infoMessage</MudAlert>
    }

    <MudPaper Class="pa-3 mb-4" Elevation="1">
        <MudSwitch T="bool" Value="requireTime" ValueChanged="OnRequireTimeChanged" Color="Color.Primary"
                   Label="Require a start time on entries" />
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            When off, entries capture the date only — the time field is hidden and time isn't shown in the list.
        </MudText>
        <MudDivider Class="my-3" />
        <MudSwitch T="bool" Value="captureLocation" ValueChanged="OnCaptureLocationChanged" Color="Color.Primary"
                   Label="Capture location with entries" />
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            When on, every new entry asks the browser for the user's location and stores
            latitude/longitude on the entry (hidden from the UI; for audit/travel reports).
            Browsers prompt members for OS-level permission the first time.
        </MudText>
    </MudPaper>

    <div class="d-flex justify-space-between align-center mb-3">
        <MudText Typo="Typo.h5">Configurable fields</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddField">Add field</MudButton>
    </div>

    @if (fields is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (fields.Count == 0)
    {
        <MudText Class="mud-text-secondary">No fields defined yet. The base note is always collected; add fields to capture more.</MudText>
    }
    else
    {
        <MudTable Items="fields" Hover="true" Dense="true" Elevation="1">
            <HeaderContent>
                <MudTh>Label</MudTh><MudTh>Key</MudTh><MudTh>Type</MudTh><MudTh>Required</MudTh>
                <MudTh>Role</MudTh><MudTh>Active</MudTh><MudTh>Sort</MudTh><MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Label</MudTd>
                <MudTd><code>@context.FieldKey</code></MudTd>
                <MudTd>@context.DataType</MudTd>
                <MudTd>@(context.IsRequired ? "Yes" : "No")</MudTd>
                <MudTd>@(context.OrganizationRoleName ?? "All roles")</MudTd>
                <MudTd>@(context.IsActive ? "Yes" : "No")</MudTd>
                <MudTd>@context.SortOrder</MudTd>
                <MudTd Style="text-align:right; white-space:nowrap">
                    <MudTooltip Text="Edit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditField(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteFieldAsync(context))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    private IReadOnlyList<OrganizationDto>? organizations;
    private IReadOnlyList<OrganizationRoleDto>? roles;
    private IReadOnlyList<EntryFieldAdminDto>? fields;
    private int selectedOrgId;
    private bool requireTime = true;
    private bool captureLocation;
    private string? infoMessage;
    private string? loadError;

    protected override Task OnInitializedAsync() => ReloadAllAsync();

    private Task ReloadAllAsync() => GuardAsync(async () =>
    {
        organizations = await Api.GetOrganizationsAsync();
        if (organizations.Count > 0)
        {
            if (selectedOrgId == 0)
            {
                selectedOrgId = organizations[0].Id;
            }
            await LoadAsync();
        }
    });

    private async Task OnOrgChanged(int orgId)
    {
        selectedOrgId = orgId;
        infoMessage = null;
        await GuardAsync(LoadAsync);
    }

    private async Task LoadAsync()
    {
        var org = organizations?.FirstOrDefault(o => o.Id == selectedOrgId);
        requireTime = org?.RequireTime ?? true;
        captureLocation = org?.CaptureLocation ?? false;
        roles = await Api.GetRolesAsync(selectedOrgId);
        fields = await Api.GetAdminFieldsAsync(selectedOrgId);
    }

    private async Task OnRequireTimeChanged(bool value)
    {
        requireTime = value;
        // The PUT replaces all entry-settings, so send both flags together.
        var result = await Api.SaveEntrySettingsAsync(selectedOrgId,
            new EntrySettingsRequest { RequireTime = value, CaptureLocation = captureLocation });
        if (result.Success)
        {
            Snackbar.Add(value ? "Start time is now required" : "Entries are now date-only", Severity.Success);
            organizations = await Api.GetOrganizationsAsync(); // refresh cached settings
        }
        else
        {
            requireTime = !value; // revert on failure
            Snackbar.Add(result.Error ?? "Could not update the setting.", Severity.Error);
        }
    }

    private async Task OnCaptureLocationChanged(bool value)
    {
        captureLocation = value;
        var result = await Api.SaveEntrySettingsAsync(selectedOrgId,
            new EntrySettingsRequest { RequireTime = requireTime, CaptureLocation = value });
        if (result.Success)
        {
            Snackbar.Add(value ? "Location will be captured with new entries" : "Location capture turned off", Severity.Success);
            organizations = await Api.GetOrganizationsAsync();
        }
        else
        {
            captureLocation = !value;
            Snackbar.Add(result.Error ?? "Could not update the setting.", Severity.Error);
        }
    }

    private async Task GuardAsync(Func<Task> action)
    {
        try
        {
            loadError = null;
            await action();
        }
        catch (ApiException ex)
        {
            loadError = ex.Message;
        }
        catch (Exception)
        {
            loadError = "Something went wrong loading the fields. Please retry.";
        }
    }

    private Task OpenAddField() => ShowFieldDialogAsync(null);

    private Task OpenEditField(EntryFieldAdminDto field) => ShowFieldDialogAsync(field);

    private async Task ShowFieldDialogAsync(EntryFieldAdminDto? field)
    {
        var nextSort = (fields is { Count: > 0 } ? fields.Max(f => f.SortOrder) : 0) + 1;
        var parameters = new DialogParameters<FieldDialog>
        {
            { x => x.OrgId, selectedOrgId },
            { x => x.Roles, roles ?? [] },
            { x => x.Existing, field },
            { x => x.NextSortOrder, nextSort },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<FieldDialog>(
            field is null ? "New field" : $"Edit \"{field.Label}\"", parameters, options);
        if (await dialog.Result is { Canceled: false })
        {
            await GuardAsync(LoadAsync);
        }
    }

    private async Task DeleteFieldAsync(EntryFieldAdminDto f)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete the field \"{f.Label}\"?"))
        {
            return;
        }

        var result = await Api.DeleteFieldAsync(selectedOrgId, f.Id);
        Snackbar.Add(result.Message, result.Deactivated ? Severity.Warning : Severity.Success);
        await LoadAsync();
    }
}
