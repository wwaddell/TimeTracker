@page "/admin/organization"
@using TimeTracker.Contracts.Organizations
@using TimeTracker.Web.Components
@using TimeTracker.Web.Services
@inject TimeTrackerApi Api
@inject IDialogService DialogService

<PageTitle>Organization</PageTitle>

@if (loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        <div class="d-flex align-center justify-space-between" style="gap:1rem">
            <span>@loadError</span>
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync">Retry</MudButton>
        </div>
    </MudAlert>
}

<MudText Typo="Typo.h5" Class="mb-1">Organizations</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Edit the details of organizations you administer.
</MudText>

@if (orgs is null)
{
    @if (loadError is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
}
else if (orgs.Count == 0)
{
    <MudAlert Severity="Severity.Warning">You don't administer any organizations.</MudAlert>
}
else
{
    <MudTable Items="orgs" Hover="true" Dense="true" Elevation="1">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Description</MudTh>
            <MudTh Style="width:1px; white-space:nowrap">Active</MudTh>
            <MudTh Style="width:1px"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><b>@context.Name</b></MudTd>
            <MudTd>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Description</MudText>
            </MudTd>
            <MudTd Style="text-align:center">
                @if (context.IsActive)
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                }
                else
                {
                    <MudTooltip Text="Inactive"><MudIcon Icon="@Icons.Material.Filled.Block" Color="Color.Default" Size="Size.Small" /></MudTooltip>
                }
            </MudTd>
            <MudTd Style="text-align:right">
                <MudTooltip Text="Edit">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   OnClick="@(() => OpenEditAsync(context))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private IReadOnlyList<OrganizationDetailsDto>? orgs;
    private string? loadError;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            loadError = null;
            orgs = await Api.GetManageableOrganizationsAsync();
        }
        catch (ApiException ex)
        {
            loadError = ex.Message;
        }
        catch (Exception)
        {
            loadError = "Something went wrong loading organizations. Please retry.";
        }
    }

    private async Task OpenEditAsync(OrganizationDetailsDto org)
    {
        var parameters = new DialogParameters<OrgDetailsDialog> { { x => x.Org, org } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<OrgDetailsDialog>($"Edit {org.Name}", parameters, options);
        if (await dialog.Result is { Canceled: false })
        {
            await LoadAsync();
        }
    }
}
