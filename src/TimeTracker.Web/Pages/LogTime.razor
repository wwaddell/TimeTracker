@page "/"
@page "/log"
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Domain.Enums
@inject TimeTracker.Web.Services.TimeTrackerApi Api

<PageTitle>Log Time</PageTitle>

<h1 class="mb-4">Log Time</h1>

@if (organizations is null)
{
    <p><em>Loading…</em></p>
}
else if (organizations.Count == 0)
{
    <div class="alert alert-warning">No organizations available for your account.</div>
}
else
{
    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Organization</label>
            <select class="form-select" @onchange="OnOrgChanged">
                @foreach (var org in organizations)
                {
                    <option value="@org.Id" selected="@(org.Id == selectedOrgId)">
                        @org.Name@(org.RoleName is null ? "" : $" — {org.RoleName}")
                    </option>
                }
            </select>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Note <span class="text-danger">*</span></label>
                <textarea class="form-control" rows="2" placeholder="What did you work on?"
                          @bind="note" @bind:event="oninput"></textarea>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-4">
                    <label class="form-label">Date</label>
                    <input type="date" class="form-control" @bind="entryDate" />
                </div>
                <div class="col-sm-4">
                    <label class="form-label">Start time</label>
                    <input type="time" class="form-control" @bind="startTime" />
                </div>
                <div class="col-sm-4">
                    <label class="form-label">Duration (min)</label>
                    <input type="number" min="0" class="form-control" @bind="durationMinutes" />
                </div>
            </div>

            @if (fields is { Count: > 0 })
            {
                <hr />
                <div class="row g-3">
                    @foreach (var field in fields)
                    {
                        <div class="col-sm-6">
                            <label class="form-label">
                                @field.Label
                                @if (field.IsRequired)
                                {
                                    <span class="text-danger">*</span>
                                }
                            </label>
                            @switch (field.DataType)
                            {
                                case FieldDataType.Boolean:
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input"
                                               checked="@IsTrue(field.Id)"
                                               @onchange="e => OnBoolChanged(field.Id, e)" />
                                    </div>
                                    break;
                                case FieldDataType.Select:
                                    <select class="form-select"
                                            @onchange="e => SetValue(field.Id, e.Value?.ToString())">
                                        <option value="">— select —</option>
                                        @foreach (var opt in field.Options)
                                        {
                                            <option value="@opt.Value" selected="@IsSelected(field.Id, opt.Value)">@opt.Label</option>
                                        }
                                    </select>
                                    break;
                                case FieldDataType.Number:
                                    <input type="number" class="form-control" value="@GetValue(field.Id)"
                                           @onchange="e => SetValue(field.Id, e.Value?.ToString())" />
                                    break;
                                case FieldDataType.Date:
                                    <input type="date" class="form-control" value="@GetValue(field.Id)"
                                           @onchange="e => SetValue(field.Id, e.Value?.ToString())" />
                                    break;
                                default:
                                    <input type="text" class="form-control" value="@GetValue(field.Id)"
                                           @onchange="e => SetValue(field.Id, e.Value?.ToString())" />
                                    break;
                            }
                        </div>
                    }
                </div>
            }

            @if (errorMessage is not null)
            {
                <div class="alert alert-danger mt-3 mb-0">@errorMessage</div>
            }
        </div>
        <div class="card-footer text-end">
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(saving || string.IsNullOrWhiteSpace(note))">
                @(saving ? "Saving…" : "Log entry")
            </button>
        </div>
    </div>

    <h2 class="h4 mb-3">Recent entries</h2>
    @if (entries is null)
    {
        <p><em>Loading…</em></p>
    }
    else if (entries.Count == 0)
    {
        <p class="text-muted">No entries yet — log your first one above.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var entry in entries)
            {
                <li class="list-group-item">
                    <div class="d-flex justify-content-between">
                        <strong>@entry.Note</strong>
                        <small class="text-muted">
                            @entry.EntryDate.ToString("yyyy-MM-dd")
                            @(entry.StartTime is { } t ? t.ToString("HH:mm") : "")
                            @(entry.DurationMinutes is { } d ? $"· {d} min" : "")
                        </small>
                    </div>
                    @if (entry.Attributes.Count > 0)
                    {
                        <div class="mt-1">
                            @foreach (var attr in entry.Attributes)
                            {
                                <span class="badge bg-secondary me-1">@attr.Label: @attr.Value</span>
                            }
                        </div>
                    }
                </li>
            }
        </ul>
    }
}

@code {
    private IReadOnlyList<OrganizationDto>? organizations;
    private IReadOnlyList<EntryFieldDto>? fields;
    private IReadOnlyList<TimeEntryDto>? entries;
    private int selectedOrgId;

    private string note = string.Empty;
    private DateOnly entryDate = DateOnly.FromDateTime(DateTime.Now);
    private TimeOnly? startTime = TimeOnly.FromDateTime(DateTime.Now);
    private int? durationMinutes;
    private readonly Dictionary<int, string?> fieldValues = new();

    private bool saving;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        organizations = await Api.GetOrganizationsAsync();
        if (organizations.Count > 0)
        {
            selectedOrgId = organizations[0].Id;
            await LoadOrgDataAsync();
        }
    }

    private async Task OnOrgChanged(ChangeEventArgs e)
    {
        selectedOrgId = int.Parse(e.Value!.ToString()!);
        fieldValues.Clear();
        await LoadOrgDataAsync();
    }

    private async Task LoadOrgDataAsync()
    {
        fields = await Api.GetEntryFieldsAsync(selectedOrgId);
        entries = await Api.GetTimeEntriesAsync(selectedOrgId);
    }

    private string? GetValue(int fieldId) => fieldValues.TryGetValue(fieldId, out var v) ? v : null;

    private void SetValue(int fieldId, string? value) => fieldValues[fieldId] = value;

    private bool IsTrue(int fieldId) => GetValue(fieldId) == "true";

    private bool IsSelected(int fieldId, string value) => GetValue(fieldId) == value;

    private void OnBoolChanged(int fieldId, ChangeEventArgs e) =>
        SetValue(fieldId, e.Value is true ? "true" : "false");

    private async Task SaveAsync()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(note))
        {
            errorMessage = "A note is required.";
            return;
        }

        // Enforce required configurable fields client-side.
        var missing = (fields ?? [])
            .Where(f => f.IsRequired && string.IsNullOrWhiteSpace(GetValue(f.Id)))
            .Select(f => f.Label)
            .ToList();
        if (missing.Count > 0)
        {
            errorMessage = $"Required: {string.Join(", ", missing)}";
            return;
        }

        saving = true;
        try
        {
            var request = new CreateTimeEntryRequest
            {
                Note = note,
                EntryDate = entryDate,
                StartTime = startTime,
                DurationMinutes = durationMinutes,
                Attributes = new Dictionary<int, string?>(fieldValues),
            };

            if (await Api.CreateTimeEntryAsync(selectedOrgId, request))
            {
                note = string.Empty;
                durationMinutes = null;
                fieldValues.Clear();
                entryDate = DateOnly.FromDateTime(DateTime.Now);
                startTime = TimeOnly.FromDateTime(DateTime.Now);
                entries = await Api.GetTimeEntriesAsync(selectedOrgId);
            }
            else
            {
                errorMessage = "Failed to save the entry. Please try again.";
            }
        }
        finally
        {
            saving = false;
        }
    }
}
