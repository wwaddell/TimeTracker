@page "/"
@page "/log"
@using TimeTracker.Contracts.Me
@using TimeTracker.Contracts.Projects
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Contracts.Tasks
@using TimeTracker.Domain.Enums
@using TimeTracker.Web.Components
@using TimeTracker.Web.Theme
@using TimeTracker.Web.Services
@inject TimeTracker.Web.Services.TimeTrackerApi Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Log Time</PageTitle>

@if (loadError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        <div class="d-flex align-center justify-space-between" style="gap:1rem">
            <span>@loadError</span>
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="ReloadAllAsync">Retry</MudButton>
        </div>
    </MudAlert>
}

@if (organizations is null)
{
    @if (loadError is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
}
else if (organizations.Count == 0)
{
    <MudAlert Severity="Severity.Warning">No organizations available for your account.</MudAlert>
}
else
{
    @* Hide the org switcher when the user only belongs to one org, or has opted to hide it. *@
    @if (organizations.Count > 1 && me?.HideOrgSwitcher != true)
    {
        <MudSelect T="int" Label="Organization" Value="selectedOrgId" ValueChanged="OnOrgChanged"
                   Variant="Variant.Outlined" Class="mb-4" Style="max-width:420px">
            @foreach (var org in organizations)
            {
                <MudSelectItem T="int" Value="@org.Id">
                    @org.Name@(org.RoleName is null ? "" : $" — {org.RoleName}")
                </MudSelectItem>
            }
        </MudSelect>
    }

    <MudPaper Class="pa-3 mb-6" Elevation="1">
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
            <MudTextField T="string" @bind-Value="quickNote" Immediate="true" Margin="Margin.Dense"
                          Lines="2" AutoGrow="true" MaxLines="8"
                          Placeholder="Quick add — just a note…" Variant="Variant.Outlined"
                          Class="flex-grow-1" />
            <MudTooltip Text="Quick add (note only)">
                <MudIconButton Icon="@Icons.Material.Filled.Bolt" Color="Color.Primary"
                               OnClick="QuickAddAsync"
                               Disabled="@(quickAdding || string.IsNullOrWhiteSpace(quickNote))" />
            </MudTooltip>
            <MudTooltip Text="Add detailed entry">
                <MudIconButton Icon="@Icons.Material.Filled.PostAdd" Color="Color.Primary"
                               Variant="Variant.Filled" OnClick="OpenAdd" />
            </MudTooltip>
        </MudStack>
        @if (me?.CompactMode != true)
        {
            <MudText Typo="Typo.caption" Class="mt-2 mud-text-secondary d-flex align-center" Style="gap:.25rem">
                Enter or <MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" />, or
                <MudIcon Icon="@Icons.Material.Filled.PostAdd" Size="Size.Small" /> for detail
            </MudText>
        }
    </MudPaper>

    <div class="d-flex justify-space-between align-center mb-3 flex-wrap" style="gap:1rem">
        @if (me?.CompactMode != true)
        {
            <MudText Typo="Typo.h5">Recent entries</MudText>
        }
        else
        {
            <span></span>
        }
        <MudSelect T="string" Value="groupBy" ValueChanged="OnGroupChanged" Dense="true"
                   Margin="Margin.Dense" Variant="Variant.Outlined" Label="Group by" Style="min-width:170px">
            <MudSelectItem T="string" Value="@("none")">None</MudSelectItem>
            <MudSelectItem T="string" Value="@("day")">Day</MudSelectItem>
            <MudSelectItem T="string" Value="@("week")">Week</MudSelectItem>
            <MudSelectItem T="string" Value="@("month")">Month</MudSelectItem>
        </MudSelect>
    </div>

    @if (entries is null)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (entries.Count == 0)
    {
        <MudText Class="mud-text-secondary">No entries yet — use Quick add or Add above.</MudText>
    }
    else
    {
        <MudStack Spacing="2">
            @{ string? renderedGroupKey = null; }
            @foreach (var entry in entries)
            {
                // Group header: when grouping is on and this entry starts a new group on the
                // page, render the band above it. Totals come from the server (full group, not
                // the page slice) so they read consistently when a group spans pages.
                if (groupBy != "none" && entry.GroupKey != renderedGroupKey)
                {
                    renderedGroupKey = entry.GroupKey;
                    var summary = groups.FirstOrDefault(g => g.Key == entry.GroupKey);
                    if (summary is not null)
                    {
                        <MudPaper Class="px-3 py-2 mb-1 d-flex justify-space-between align-center" Elevation="0" Outlined="true">
                            <MudText Typo="Typo.subtitle2"><b>@summary.Label</b></MudText>
                            <div class="d-flex align-center" style="gap:.75rem">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @FormatHours(summary.TotalMinutes) · @summary.EntryCount @(summary.EntryCount == 1 ? "entry" : "entries")
                                </MudText>
                                @if (summary.IssueCount > 0)
                                {
                                    <MudTooltip Text="Entries missing required fields">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                                                 Icon="@Icons.Material.Filled.Warning">
                                            @summary.IssueCount @(summary.IssueCount == 1 ? "issue" : "issues")
                                        </MudChip>
                                    </MudTooltip>
                                }
                            </div>
                        </MudPaper>
                    }
                }
                var missing = MissingLabels(entry);
                var attrs = entry.Attributes.Where(a => !string.IsNullOrWhiteSpace(a.Value) && a.Value != "false").ToList();
                // Header = Project / Task (bold). Prefer the first-class ProjectName (FK) over
                // the legacy "Project" attribute, but keep the attribute fallback for old data.
                var legacyProject = attrs.FirstOrDefault(a => string.Equals(a.Label, "Project", StringComparison.OrdinalIgnoreCase));
                var projectName = entry.ProjectName ?? legacyProject?.Value;
                var headerParts = new List<string>();
                if (!string.IsNullOrWhiteSpace(projectName)) { headerParts.Add(projectName); }
                if (entry.TaskTitle is not null) { headerParts.Add(entry.TaskTitle); }
                var hasHeader = headerParts.Count > 0;
                var header = string.Join(" · ", headerParts);
                var cat = CategoryFor(entry);
                // Lead glyph: the category's icon if set, else a project/task/default icon — so
                // every row has a consistent header.
                var leadIcon = cat.Icon
                    ?? (!string.IsNullOrWhiteSpace(projectName) ? Icons.Material.Filled.Folder
                        : entry.TaskTitle is not null ? Icons.Material.Filled.Assignment
                        : Icons.Material.Filled.Schedule);
                // Below: hide the legacy Project attribute (it's in the header) and Category (icon).
                var detailAttrs = attrs.Where(a =>
                    (legacyProject is null || a.FieldId != legacyProject.FieldId)
                    && (cat.Icon is null || a.FieldId != cat.FieldId)).ToList();
                <MudPaper Class="pa-4" Outlined="true" Style="cursor:pointer"
                          @onclick="@(() => OpenEdit(entry))">
                    <div class="d-flex justify-space-between" style="gap:1rem">
                        <div class="d-flex align-center" style="gap:.35rem; min-width:0">
                            @if (cat.Icon is not null)
                            {
                                <MudTooltip Text="@cat.Label">
                                    <MudIcon Icon="@leadIcon" Size="Size.Small" Color="Color.Primary" />
                                </MudTooltip>
                            }
                            else
                            {
                                <MudIcon Icon="@leadIcon" Size="Size.Small" Color="Color.Primary" />
                            }
                            @if (hasHeader)
                            {
                                <MudText Typo="Typo.subtitle1" Style="font-weight:600; word-break:break-word">@header</MudText>
                            }
                            @if (entry.Source == TimeEntrySource.OutlookGraph)
                            {
                                <MudTooltip Text="Imported from Outlook">
                                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" Class="mud-text-secondary" />
                                </MudTooltip>
                            }
                            @if (entry.SourceIsRecurring)
                            {
                                <MudTooltip Text="Recurring meeting">
                                    <MudIcon Icon="@Icons.Material.Filled.Repeat" Size="Size.Small" Class="mud-text-secondary" />
                                </MudTooltip>
                            }
                        </div>
                        <div class="d-flex align-center flex-none" style="gap:.25rem">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="white-space:nowrap">
                                @entry.EntryDate.ToString("yyyy-MM-dd")
                                @(OrgRequiresTime && entry.StartTime is { } t ? "· " + t.ToString("HH:mm") : "")
                                @(entry.DurationMinutes is { } d ? $"· {d} min" : "")
                            </MudText>
                            @if (missing.Count > 0)
                            {
                                <span @onclick:stopPropagation="true" @onclick="@(() => { })">
                                    <MudMenu Icon="@Icons.Material.Filled.Warning" IconColor="Color.Warning" Size="Size.Small"
                                             Dense="true" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopRight"
                                             aria-label="Incomplete — show missing fields">
                                        <MudText Typo="Typo.subtitle2" Class="px-4 pt-2 pb-1">Missing required</MudText>
                                        @foreach (var m in missing)
                                        {
                                            <MudMenuItem Icon="@Icons.Material.Outlined.ErrorOutline" IconColor="Color.Warning">@m</MudMenuItem>
                                        }
                                    </MudMenu>
                                </span>
                            }
                        </div>
                    </div>

                    @* Details below the header: the note, then the remaining field values. *@
                    @if (!string.IsNullOrWhiteSpace(entry.Note))
                    {
                        <MudText Typo="Typo.body2" Class="mt-1" Style="word-break:break-word">@entry.Note</MudText>
                    }
                    @if (detailAttrs.Count > 0)
                    {
                        <MudChipSet T="string" Class="mt-2" ReadOnly="true">
                            @foreach (var attr in detailAttrs)
                            {
                                @if (attr.Value == "true")
                                {
                                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                                             Icon="@Icons.Material.Filled.Check">@attr.Label</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small">@attr.Label: @attr.Value</MudChip>
                                }
                            }
                        </MudChipSet>
                    }
                </MudPaper>
            }
        </MudStack>

        <div class="d-flex justify-space-between align-center mt-4">
            <MudText Typo="Typo.caption" Class="mud-text-secondary">@total @(total == 1 ? "entry" : "entries")</MudText>
            <MudPagination Count="@TotalPages" Selected="page" SelectedChanged="OnPageChanged" Color="Color.Primary" />
        </div>
    }
}

@code {
    private const int PageSize = 10;

    private IReadOnlyList<OrganizationDto>? organizations;
    private MeDto? me;
    private IReadOnlyList<EntryFieldDto>? fields;
    private IReadOnlyList<TaskDto>? tasks;
    private IReadOnlyList<ProjectPickerDto>? projects;
    private IReadOnlyList<TimeEntryDto>? entries;
    private IReadOnlyList<TimeEntryGroupDto> groups = [];
    private string groupBy = "none"; // "none" | "day" | "week" | "month"

    private async Task OnGroupChanged(string value)
    {
        groupBy = value;
        page = 1;
        await GuardAsync(LoadEntriesAsync);
    }

    // "92" minutes → "1h 32m"; "60" → "1h"; "0" or null → "0m".
    private static string FormatHours(int minutes)
    {
        if (minutes <= 0) return "0m";
        var h = minutes / 60;
        var m = minutes % 60;
        return (h, m) switch
        {
            (0, _) => $"{m}m",
            (_, 0) => $"{h}h",
            _ => $"{h}h {m}m",
        };
    }
    private int selectedOrgId;
    private int page = 1;
    private int total;

    private string quickNote = string.Empty;
    private bool quickAdding;
    private string? loadError;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(total / (double)PageSize));

    private bool OrgRequiresTime =>
        organizations?.FirstOrDefault(o => o.Id == selectedOrgId)?.RequireTime ?? true;

    private DotNetObjectReference<LogTime>? _selfRef;
    private bool _quickEnterBound;

    protected override Task OnInitializedAsync()
    {
        _selfRef = DotNetObjectReference.Create(this);
        return ReloadAllAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Bind the Enter-to-submit / Shift+Enter-newline handler once the quick-add box exists.
        if (!_quickEnterBound && organizations is { Count: > 0 } && _selfRef is not null)
        {
            var bound = await JS.InvokeAsync<bool>("ttQuickAdd.bind", "textarea[placeholder^='Quick add']", _selfRef);
            _quickEnterBound = bound;
        }
    }

    [JSInvokable]
    public async Task OnQuickEnter()
    {
        await QuickAddAsync();
        StateHasChanged();
    }

    public void Dispose() => _selfRef?.Dispose();

    private Task ReloadAllAsync() => GuardAsync(async () =>
    {
        organizations = await Api.GetOrganizationsAsync();
        me ??= await Api.GetMeAsync(); // for HideOrgSwitcher preference
        if (organizations.Count > 0)
        {
            if (selectedOrgId == 0)
            {
                selectedOrgId = organizations[0].Id;
            }
            await LoadOrgDataAsync();
        }
    });

    private async Task OnOrgChanged(int orgId)
    {
        selectedOrgId = orgId;
        page = 1;
        await GuardAsync(LoadOrgDataAsync);
    }

    // Runs a load action, surfacing failures as a friendly retryable banner instead of crashing.
    private async Task GuardAsync(Func<Task> action)
    {
        try
        {
            loadError = null;
            await action();
        }
        catch (ApiException ex)
        {
            loadError = ex.Message;
        }
        catch (Exception)
        {
            loadError = "Something went wrong loading your data. Please retry.";
        }
    }

    private async Task LoadOrgDataAsync()
    {
        fields = await Api.GetEntryFieldsAsync(selectedOrgId);
        tasks = await Api.GetTasksAsync(selectedOrgId);
        projects = await Api.GetVisibleProjectsAsync(selectedOrgId);
        await LoadEntriesAsync();
    }

    private async Task LoadEntriesAsync()
    {
        var groupParam = groupBy == "none" ? null : groupBy;
        var result = await Api.GetTimeEntriesAsync(selectedOrgId, page, PageSize, groupParam);
        entries = result.Items;
        groups = result.Groups;
        total = result.Total;
        if (page > TotalPages)
        {
            page = TotalPages;
            var clamped = await Api.GetTimeEntriesAsync(selectedOrgId, page, PageSize, groupParam);
            entries = clamped.Items;
            groups = clamped.Groups;
            total = clamped.Total;
        }
    }

    private async Task OnPageChanged(int newPage)
    {
        page = newPage;
        await GuardAsync(LoadEntriesAsync);
    }

    private async Task QuickAddAsync()
    {
        if (string.IsNullOrWhiteSpace(quickNote))
        {
            return;
        }

        quickAdding = true;
        try
        {
            var ctx = await CaptureContextAsync();
            var request = new CreateTimeEntryRequest
            {
                Note = quickNote.Trim(),
                EntryDate = DateOnly.FromDateTime(DateTime.Now),
                StartTime = OrgRequiresTime ? TimeOnly.FromDateTime(DateTime.Now) : null,
                Timezone = ctx.Timezone,
                Latitude = ctx.Latitude,
                Longitude = ctx.Longitude,
                LocationAccuracy = ctx.LocationAccuracy,
            };
            var result = await Api.CreateTimeEntryAsync(selectedOrgId, request);
            if (result.Success)
            {
                quickNote = string.Empty;
                page = 1;
                await GuardAsync(LoadEntriesAsync);
                Snackbar.Add("Entry logged", Severity.Success);
            }
            else
            {
                Snackbar.Add(result.Error ?? "Could not log the entry.", Severity.Error);
            }
        }
        finally
        {
            quickAdding = false;
        }
    }

    private Task OpenAdd() => ShowDialogAsync(null);

    private Task OpenEdit(TimeEntryDto entry) => ShowDialogAsync(entry);

    private async Task ShowDialogAsync(TimeEntryDto? entry)
    {
        var parameters = new DialogParameters<TimeEntryDialog>
        {
            { x => x.OrgId, selectedOrgId },
            { x => x.Fields, fields ?? [] },
            { x => x.Tasks, tasks },
            { x => x.Projects, projects ?? [] },
            { x => x.Entry, entry },
            { x => x.RequireTime, OrgRequiresTime },
            { x => x.CaptureLocation, me?.CaptureLocation ?? false },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<TimeEntryDialog>(
            entry is null ? "Add entry" : "Edit entry", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            if (entry is null) { page = 1; }
            // Reload tasks too — the entry may have adjusted a task's progress.
            await GuardAsync(async () =>
            {
                tasks = await Api.GetTasksAsync(selectedOrgId);
                await LoadEntriesAsync();
            });
        }
    }

    // Resolves the entry's Category to a header icon (from the option's assigned icon) + label.
    private (string? Icon, string? Label, int FieldId) CategoryFor(TimeEntryDto entry)
    {
        var field = (fields ?? []).FirstOrDefault(f =>
            string.Equals(f.FieldKey, "category", StringComparison.OrdinalIgnoreCase)
            || string.Equals(f.Label, "category", StringComparison.OrdinalIgnoreCase));
        if (field is null)
        {
            return (null, null, 0);
        }

        var attr = entry.Attributes.FirstOrDefault(a => a.FieldId == field.Id && !string.IsNullOrWhiteSpace(a.Value));
        if (attr is null)
        {
            return (null, null, field.Id);
        }

        var option = field.Options.FirstOrDefault(o => o.Value == attr.Value);
        return (EntryIconPalette.Resolve(option?.Icon), option?.Label ?? attr.Value, field.Id);
    }

    private List<string> MissingLabels(TimeEntryDto entry)
    {
        var filled = entry.Attributes
            .Where(a => !string.IsNullOrWhiteSpace(a.Value))
            .Select(a => a.FieldId)
            .ToHashSet();
        return (fields ?? [])
            .Where(f => f.IsRequired && !filled.Contains(f.Id))
            .Select(f => f.Label)
            .ToList();
    }

    /// <summary>
    /// Asks the browser for the hidden auto-capture context (always: timezone; opt-in: location).
    /// Best-effort — if anything fails, returns nulls so the entry still saves.
    /// </summary>
    private async Task<EntryContext> CaptureContextAsync()
    {
        try
        {
            var includeLoc = me?.CaptureLocation ?? false;
            var raw = await JS.InvokeAsync<EntryContextRaw>("ttContext.captureEntryContext", includeLoc);
            return new EntryContext(raw.Timezone, raw.Latitude, raw.Longitude, raw.LocationAccuracy);
        }
        catch
        {
            return new EntryContext(null, null, null, null);
        }
    }

    private readonly record struct EntryContext(string? Timezone, double? Latitude, double? Longitude, double? LocationAccuracy);
    private class EntryContextRaw
    {
        public string? Timezone { get; set; }
        public double? Latitude { get; set; }
        public double? Longitude { get; set; }
        public double? LocationAccuracy { get; set; }
    }
}
