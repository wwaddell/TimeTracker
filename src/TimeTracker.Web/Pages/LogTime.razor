@page "/"
@page "/log"
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Contracts.Tasks
@using TimeTracker.Web.Components
@using TimeTracker.Web.Models
@inject TimeTracker.Web.Services.TimeTrackerApi Api
@inject IJSRuntime JS

<PageTitle>Log Time</PageTitle>

@if (organizations is null)
{
    <p><em>Loading…</em></p>
}
else if (organizations.Count == 0)
{
    <div class="alert alert-warning">No organizations available for your account.</div>
}
else
{
    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Organization</label>
            <select class="form-select" @onchange="OnOrgChanged">
                @foreach (var org in organizations)
                {
                    <option value="@org.Id" selected="@(org.Id == selectedOrgId)">
                        @org.Name@(org.RoleName is null ? "" : $" — {org.RoleName}")
                    </option>
                }
            </select>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="input-group">
                <input class="form-control" placeholder="Quick add — just a note…"
                       @bind="quickNote" @bind:event="oninput" @onkeydown="QuickKeyDown" />
                <button class="btn btn-outline-primary" @onclick="QuickAddAsync"
                        disabled="@(quickAdding || string.IsNullOrWhiteSpace(quickNote))">
                    @(quickAdding ? "Adding…" : "Quick add")
                </button>
                <button class="btn btn-primary" @onclick="OpenAdd">Add…</button>
            </div>
            <div class="form-text">
                Quick add logs just the note now — rows still missing required fields are flagged so you can finish them later.
            </div>
        </div>
    </div>

    <h2 class="h4 mb-3">Recent entries</h2>
    @if (entries is null)
    {
        <p><em>Loading…</em></p>
    }
    else if (entries.Count == 0)
    {
        <p class="text-muted">No entries yet — use Quick add or Add above.</p>
    }
    else
    {
        <div class="list-group">
            @foreach (var entry in entries)
            {
                <button type="button" class="list-group-item list-group-item-action" @onclick="() => OpenEdit(entry)">
                    <div class="d-flex justify-content-between">
                        <strong>
                            @entry.Note
                            @if (MissingLabels(entry) is { Count: > 0 } missing)
                            {
                                <span class="badge bg-warning text-dark ms-2"
                                      title="@($"Missing required: {string.Join(", ", missing)}")">⚠ Incomplete</span>
                            }
                        </strong>
                        <small class="text-muted">
                            @entry.EntryDate.ToString("yyyy-MM-dd")
                            @(entry.StartTime is { } t ? t.ToString("HH:mm") : "")
                            @(entry.DurationMinutes is { } d ? $"· {d} min" : "")
                        </small>
                    </div>
                    @if (entry.TaskTitle is not null || entry.Attributes.Any(a => !string.IsNullOrWhiteSpace(a.Value)))
                    {
                        <div class="mt-1">
                            @if (entry.TaskTitle is not null)
                            {
                                <span class="badge bg-info text-dark me-1">Task: @entry.TaskTitle</span>
                            }
                            @foreach (var attr in entry.Attributes.Where(a => !string.IsNullOrWhiteSpace(a.Value)))
                            {
                                <span class="badge bg-secondary me-1">@attr.Label: @attr.Value</span>
                            }
                        </div>
                    }
                </button>
            }
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <small class="text-muted">@total @(total == 1 ? "entry" : "entries")</small>
            <div class="btn-group">
                <button class="btn btn-sm btn-outline-secondary" @onclick="PrevPage" disabled="@(page <= 1)">‹ Prev</button>
                <span class="btn btn-sm disabled">Page @(page) of @TotalPages</span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="NextPage" disabled="@(page >= TotalPages)">Next ›</button>
            </div>
        </div>
    }
}

@if (dialogOpen && dialogModel is not null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(dialogEntryId is null ? "Add entry" : "Edit entry")</h5>
                    <button type="button" class="btn-close" @onclick="CloseDialog"></button>
                </div>
                <div class="modal-body">
                    <TimeEntryFields Model="dialogModel" Fields="fields ?? []" Tasks="tasks" />
                    @if (dialogError is not null)
                    {
                        <div class="alert alert-danger mt-3 mb-0">@dialogError</div>
                    }
                </div>
                <div class="modal-footer">
                    @if (dialogEntryId is not null)
                    {
                        <button class="btn btn-outline-danger me-auto" @onclick="DeleteDialogAsync" disabled="@dialogSaving">Delete</button>
                    }
                    <button class="btn btn-link" @onclick="CloseDialog">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveDialogAsync" disabled="@dialogSaving">
                        @(dialogSaving ? "Saving…" : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@code {
    private const int PageSize = 10;

    private IReadOnlyList<OrganizationDto>? organizations;
    private IReadOnlyList<EntryFieldDto>? fields;
    private IReadOnlyList<TaskDto>? tasks;
    private IReadOnlyList<TimeEntryDto>? entries;
    private int selectedOrgId;
    private int page = 1;
    private int total;

    private string quickNote = string.Empty;
    private bool quickAdding;

    private bool dialogOpen;
    private long? dialogEntryId;
    private TimeEntryModel? dialogModel;
    private bool dialogSaving;
    private string? dialogError;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(total / (double)PageSize));

    protected override async Task OnInitializedAsync()
    {
        organizations = await Api.GetOrganizationsAsync();
        if (organizations.Count > 0)
        {
            selectedOrgId = organizations[0].Id;
            await LoadOrgDataAsync();
        }
    }

    private async Task OnOrgChanged(ChangeEventArgs e)
    {
        selectedOrgId = int.Parse(e.Value!.ToString()!);
        page = 1;
        await LoadOrgDataAsync();
    }

    private async Task LoadOrgDataAsync()
    {
        fields = await Api.GetEntryFieldsAsync(selectedOrgId);
        tasks = await Api.GetTasksAsync(selectedOrgId);
        await LoadEntriesAsync();
    }

    private async Task LoadEntriesAsync()
    {
        var result = await Api.GetTimeEntriesAsync(selectedOrgId, page, PageSize);
        entries = result.Items;
        total = result.Total;
        if (page > TotalPages)
        {
            page = TotalPages;
            var clamped = await Api.GetTimeEntriesAsync(selectedOrgId, page, PageSize);
            entries = clamped.Items;
            total = clamped.Total;
        }
    }

    private async Task PrevPage()
    {
        if (page > 1) { page--; await LoadEntriesAsync(); }
    }

    private async Task NextPage()
    {
        if (page < TotalPages) { page++; await LoadEntriesAsync(); }
    }

    private async Task QuickKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await QuickAddAsync();
        }
    }

    private async Task QuickAddAsync()
    {
        if (string.IsNullOrWhiteSpace(quickNote))
        {
            return;
        }

        quickAdding = true;
        try
        {
            var request = new CreateTimeEntryRequest
            {
                Note = quickNote.Trim(),
                EntryDate = DateOnly.FromDateTime(DateTime.Now),
                StartTime = TimeOnly.FromDateTime(DateTime.Now),
            };
            var result = await Api.CreateTimeEntryAsync(selectedOrgId, request);
            if (result.Success)
            {
                quickNote = string.Empty;
                page = 1;
                await LoadEntriesAsync();
            }
        }
        finally
        {
            quickAdding = false;
        }
    }

    private void OpenAdd()
    {
        dialogEntryId = null;
        dialogModel = new TimeEntryModel();
        dialogError = null;
        dialogOpen = true;
    }

    private void OpenEdit(TimeEntryDto entry)
    {
        dialogEntryId = entry.Id;
        dialogModel = new TimeEntryModel
        {
            Note = entry.Note,
            EntryDate = entry.EntryDate,
            StartTime = entry.StartTime,
            DurationMinutes = entry.DurationMinutes,
            TaskId = entry.TaskId,
            Attributes = entry.Attributes.ToDictionary(a => a.FieldId, a => a.Value),
        };
        dialogError = null;
        dialogOpen = true;
    }

    private void CloseDialog()
    {
        dialogOpen = false;
        dialogModel = null;
        dialogEntryId = null;
        dialogError = null;
    }

    private async Task SaveDialogAsync()
    {
        if (dialogModel is null)
        {
            return;
        }

        dialogError = Validate(dialogModel);
        if (dialogError is not null)
        {
            return;
        }

        dialogSaving = true;
        try
        {
            var request = ToRequest(dialogModel);
            var result = dialogEntryId is null
                ? await Api.CreateTimeEntryAsync(selectedOrgId, request)
                : await Api.UpdateTimeEntryAsync(selectedOrgId, dialogEntryId.Value, request);

            if (result.Success)
            {
                if (dialogEntryId is null) { page = 1; }
                CloseDialog();
                await LoadEntriesAsync();
            }
            else
            {
                dialogError = result.Error;
            }
        }
        finally
        {
            dialogSaving = false;
        }
    }

    private async Task DeleteDialogAsync()
    {
        if (dialogEntryId is null)
        {
            return;
        }

        if (!await JS.InvokeAsync<bool>("confirm", "Delete this time entry?"))
        {
            return;
        }

        dialogSaving = true;
        try
        {
            var result = await Api.DeleteTimeEntryAsync(selectedOrgId, dialogEntryId.Value);
            if (result.Success)
            {
                CloseDialog();
                await LoadEntriesAsync();
            }
            else
            {
                dialogError = result.Error;
            }
        }
        finally
        {
            dialogSaving = false;
        }
    }

    // Required fields (for the current org) that this entry hasn't filled in.
    private List<string> MissingLabels(TimeEntryDto entry)
    {
        var filled = entry.Attributes
            .Where(a => !string.IsNullOrWhiteSpace(a.Value))
            .Select(a => a.FieldId)
            .ToHashSet();
        return (fields ?? [])
            .Where(f => f.IsRequired && !filled.Contains(f.Id))
            .Select(f => f.Label)
            .ToList();
    }

    private string? Validate(TimeEntryModel model)
    {
        if (string.IsNullOrWhiteSpace(model.Note))
        {
            return "A note is required.";
        }

        var missing = (fields ?? [])
            .Where(f => f.IsRequired &&
                string.IsNullOrWhiteSpace(model.Attributes.TryGetValue(f.Id, out var v) ? v : null))
            .Select(f => f.Label)
            .ToList();
        return missing.Count > 0 ? $"Required: {string.Join(", ", missing)}" : null;
    }

    private static CreateTimeEntryRequest ToRequest(TimeEntryModel model) => new()
    {
        Note = model.Note,
        EntryDate = model.EntryDate,
        StartTime = model.StartTime,
        DurationMinutes = model.DurationMinutes,
        TaskId = model.TaskId,
        Attributes = new Dictionary<int, string?>(model.Attributes),
    };
}
