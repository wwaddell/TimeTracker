@page "/"
@page "/log"
@using TimeTracker.Contracts.TimeEntries
@using TimeTracker.Contracts.Tasks
@using TimeTracker.Web.Components
@using TimeTracker.Web.Models
@inject TimeTracker.Web.Services.TimeTrackerApi Api
@inject IJSRuntime JS

<PageTitle>Log Time</PageTitle>

<h1 class="mb-4">Log Time</h1>

@if (organizations is null)
{
    <p><em>Loading…</em></p>
}
else if (organizations.Count == 0)
{
    <div class="alert alert-warning">No organizations available for your account.</div>
}
else
{
    <div class="row mb-3">
        <div class="col-md-6">
            <label class="form-label">Organization</label>
            <select class="form-select" @onchange="OnOrgChanged">
                @foreach (var org in organizations)
                {
                    <option value="@org.Id" selected="@(org.Id == selectedOrgId)">
                        @org.Name@(org.RoleName is null ? "" : $" — {org.RoleName}")
                    </option>
                }
            </select>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <TimeEntryFields Model="createModel" Fields="fields ?? []" Tasks="tasks" />
            @if (createError is not null)
            {
                <div class="alert alert-danger mt-3 mb-0">@createError</div>
            }
        </div>
        <div class="card-footer text-end">
            <button class="btn btn-primary" @onclick="SaveCreateAsync" disabled="@saving">
                @(saving ? "Saving…" : "Log entry")
            </button>
        </div>
    </div>

    <h2 class="h4 mb-3">Recent entries</h2>
    @if (entries is null)
    {
        <p><em>Loading…</em></p>
    }
    else if (entries.Count == 0)
    {
        <p class="text-muted">No entries yet — log your first one above.</p>
    }
    else
    {
        <div class="list-group">
            @foreach (var entry in entries)
            {
                <button type="button" class="list-group-item list-group-item-action" @onclick="() => OpenEdit(entry)">
                    <div class="d-flex justify-content-between">
                        <strong>@entry.Note</strong>
                        <small class="text-muted">
                            @entry.EntryDate.ToString("yyyy-MM-dd")
                            @(entry.StartTime is { } t ? t.ToString("HH:mm") : "")
                            @(entry.DurationMinutes is { } d ? $"· {d} min" : "")
                        </small>
                    </div>
                    @if (entry.TaskTitle is not null || entry.Attributes.Count > 0)
                    {
                        <div class="mt-1">
                            @if (entry.TaskTitle is not null)
                            {
                                <span class="badge bg-info text-dark me-1">Task: @entry.TaskTitle</span>
                            }
                            @foreach (var attr in entry.Attributes)
                            {
                                <span class="badge bg-secondary me-1">@attr.Label: @attr.Value</span>
                            }
                        </div>
                    }
                </button>
            }
        </div>
    }
}

@if (editEntry is not null && editModel is not null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit entry</h5>
                    <button type="button" class="btn-close" @onclick="CloseEdit"></button>
                </div>
                <div class="modal-body">
                    <TimeEntryFields Model="editModel" Fields="fields ?? []" Tasks="tasks" />
                    @if (editError is not null)
                    {
                        <div class="alert alert-danger mt-3 mb-0">@editError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-danger me-auto" @onclick="DeleteEditAsync" disabled="@editSaving">Delete</button>
                    <button class="btn btn-link" @onclick="CloseEdit">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveEditAsync" disabled="@editSaving">
                        @(editSaving ? "Saving…" : "Save changes")
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@code {
    private IReadOnlyList<OrganizationDto>? organizations;
    private IReadOnlyList<EntryFieldDto>? fields;
    private IReadOnlyList<TaskDto>? tasks;
    private IReadOnlyList<TimeEntryDto>? entries;
    private int selectedOrgId;

    private TimeEntryModel createModel = new();
    private bool saving;
    private string? createError;

    private TimeEntryDto? editEntry;
    private TimeEntryModel? editModel;
    private bool editSaving;
    private string? editError;

    protected override async Task OnInitializedAsync()
    {
        organizations = await Api.GetOrganizationsAsync();
        if (organizations.Count > 0)
        {
            selectedOrgId = organizations[0].Id;
            await LoadOrgDataAsync();
        }
    }

    private async Task OnOrgChanged(ChangeEventArgs e)
    {
        selectedOrgId = int.Parse(e.Value!.ToString()!);
        createModel = new TimeEntryModel();
        createError = null;
        await LoadOrgDataAsync();
    }

    private async Task LoadOrgDataAsync()
    {
        fields = await Api.GetEntryFieldsAsync(selectedOrgId);
        tasks = await Api.GetTasksAsync(selectedOrgId);
        entries = await Api.GetTimeEntriesAsync(selectedOrgId);
    }

    private async Task SaveCreateAsync()
    {
        createError = Validate(createModel);
        if (createError is not null)
        {
            return;
        }

        saving = true;
        try
        {
            var result = await Api.CreateTimeEntryAsync(selectedOrgId, ToRequest(createModel));
            if (result.Success)
            {
                createModel = new TimeEntryModel();
                entries = await Api.GetTimeEntriesAsync(selectedOrgId);
            }
            else
            {
                createError = result.Error;
            }
        }
        finally
        {
            saving = false;
        }
    }

    private void OpenEdit(TimeEntryDto entry)
    {
        editEntry = entry;
        editModel = new TimeEntryModel
        {
            Note = entry.Note,
            EntryDate = entry.EntryDate,
            StartTime = entry.StartTime,
            DurationMinutes = entry.DurationMinutes,
            TaskId = entry.TaskId,
            Attributes = entry.Attributes.ToDictionary(a => a.FieldId, a => a.Value),
        };
        editError = null;
    }

    private void CloseEdit()
    {
        editEntry = null;
        editModel = null;
        editError = null;
    }

    private async Task SaveEditAsync()
    {
        if (editEntry is null || editModel is null)
        {
            return;
        }

        editError = Validate(editModel);
        if (editError is not null)
        {
            return;
        }

        editSaving = true;
        try
        {
            var result = await Api.UpdateTimeEntryAsync(selectedOrgId, editEntry.Id, ToRequest(editModel));
            if (result.Success)
            {
                CloseEdit();
                entries = await Api.GetTimeEntriesAsync(selectedOrgId);
            }
            else
            {
                editError = result.Error;
            }
        }
        finally
        {
            editSaving = false;
        }
    }

    private async Task DeleteEditAsync()
    {
        if (editEntry is null)
        {
            return;
        }

        if (!await JS.InvokeAsync<bool>("confirm", "Delete this time entry?"))
        {
            return;
        }

        editSaving = true;
        try
        {
            var result = await Api.DeleteTimeEntryAsync(selectedOrgId, editEntry.Id);
            if (result.Success)
            {
                CloseEdit();
                entries = await Api.GetTimeEntriesAsync(selectedOrgId);
            }
            else
            {
                editError = result.Error;
            }
        }
        finally
        {
            editSaving = false;
        }
    }

    private string? Validate(TimeEntryModel model)
    {
        if (string.IsNullOrWhiteSpace(model.Note))
        {
            return "A note is required.";
        }

        var missing = (fields ?? [])
            .Where(f => f.IsRequired &&
                string.IsNullOrWhiteSpace(model.Attributes.TryGetValue(f.Id, out var v) ? v : null))
            .Select(f => f.Label)
            .ToList();
        return missing.Count > 0 ? $"Required: {string.Join(", ", missing)}" : null;
    }

    private static CreateTimeEntryRequest ToRequest(TimeEntryModel model) => new()
    {
        Note = model.Note,
        EntryDate = model.EntryDate,
        StartTime = model.StartTime,
        DurationMinutes = model.DurationMinutes,
        TaskId = model.TaskId,
        Attributes = new Dictionary<int, string?>(model.Attributes),
    };
}
