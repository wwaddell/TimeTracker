<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:TimeTracker.Mobile.Pages"
       x:Class="TimeTracker.Mobile.AppShell"
       Title="TimeTracker">

    <!-- Bottom tab bar: the two things the mobile app is for. Admin lives on the web. -->
    <TabBar>
        <Tab Title="Log Time" Icon="tab_time.png">
            <ShellContent ContentTemplate="{DataTemplate pages:LogTimePage}" Route="logtime" />
        </Tab>
        <Tab Title="Tasks" Icon="tab_tasks.png">
            <ShellContent ContentTemplate="{DataTemplate pages:TasksPage}" Route="tasks" />
        </Tab>
    </TabBar>

</Shell>
