<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand palette mirrors the web AppTheme (Primary #2563EB). -->
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="Secondary">#5B8DEF</Color>
    <Color x:Key="Success">#16A34A</Color>
    <Color x:Key="Warning">#D97706</Color>
    <Color x:Key="Error">#DC2626</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray900">#111827</Color>

</ResourceDictionary>
