<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:tk="clr-namespace:TimeTracker.Contracts.Tasks;assembly=TimeTracker.Contracts"
             x:Class="TimeTracker.Mobile.Pages.TasksPage"
             Title="Tasks">
    <Grid RowDefinitions="Auto,*">

        <Picker x:Name="OrgPicker" Grid.Row="0" Title="Organization" Margin="12,8"
                SelectedIndexChanged="OnOrgChanged" />

        <RefreshView Grid.Row="1" x:Name="Refresh" Refreshing="OnRefresh">
            <CollectionView x:Name="TasksView" SelectionMode="Single" SelectionChanged="OnTaskSelected">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="No tasks yet." HorizontalOptions="Center" TextColor="{StaticResource Gray500}" />
                        <Label Text="Tap + to create one." HorizontalOptions="Center" TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="tk:TaskDto">
                        <Grid Padding="16,10" ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                            <CheckBox Grid.RowSpan="2" Grid.Column="0" IsChecked="{Binding IsComplete}" InputTransparent="True" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Title}" FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Row="0" Grid.Column="2" Text="{Binding PercentComplete, StringFormat='{0}%'}"
                                   TextColor="{StaticResource Primary}" FontSize="12" />
                            <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Description}"
                                   FontSize="12" TextColor="{StaticResource Gray500}"
                                   LineBreakMode="TailTruncation" MaxLines="2" />
                            <BoxView Grid.Row="1" Grid.ColumnSpan="3" HeightRequest="1" Margin="0,8,0,0"
                                     Color="{StaticResource Gray200}" VerticalOptions="End" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button Grid.Row="1" Text="+" FontSize="28" Clicked="OnAddClicked"
                CornerRadius="28" HeightRequest="56" WidthRequest="56"
                BackgroundColor="{StaticResource Primary}" TextColor="White"
                HorizontalOptions="End" VerticalOptions="End" Margin="0,0,20,20" />
    </Grid>
</ContentPage>
