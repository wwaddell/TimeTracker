<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:te="clr-namespace:TimeTracker.Contracts.TimeEntries;assembly=TimeTracker.Contracts"
             x:Class="TimeTracker.Mobile.Pages.LogTimePage"
             Title="Log Time">
    <Grid RowDefinitions="Auto,*">

        <!-- Org picker (hidden when the user has just one org) -->
        <Picker x:Name="OrgPicker" Grid.Row="0" Title="Organization" Margin="12,8"
                SelectedIndexChanged="OnOrgChanged" />

        <RefreshView Grid.Row="1" x:Name="Refresh" Refreshing="OnRefresh">
            <CollectionView x:Name="EntriesView" SelectionMode="Single" SelectionChanged="OnEntrySelected">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="No time entries yet." HorizontalOptions="Center"
                               TextColor="{StaticResource Gray500}" />
                        <Label Text="Tap + to add your first one." HorizontalOptions="Center"
                               TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="te:TimeEntryDto">
                        <Grid Padding="16,10" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <Label Grid.Row="0" Grid.Column="0" Text="{Binding Note}" FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" MaxLines="2" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding DurationMinutes, StringFormat='{0} min'}"
                                   TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" FontSize="12"
                                   TextColor="{StaticResource Gray500}"
                                   Text="{Binding EntryDate, StringFormat='{0:ddd, MMM d}'}" />
                            <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Margin="0,8,0,0"
                                     Color="{StaticResource Gray200}" VerticalOptions="End" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Floating add button -->
        <Button Grid.Row="1" Text="+" FontSize="28" Clicked="OnAddClicked"
                CornerRadius="28" HeightRequest="56" WidthRequest="56"
                BackgroundColor="{StaticResource Primary}" TextColor="White"
                HorizontalOptions="End" VerticalOptions="End" Margin="0,0,20,20" />
    </Grid>
</ContentPage>
