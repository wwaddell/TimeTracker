<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TimeTracker.Mobile.Pages.AddTimeEntryPage"
             Title="Time Entry">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <Label Text="Note" FontAttributes="Bold" />
            <Editor x:Name="NoteEditor" AutoSize="TextChanges" MinimumHeightRequest="80"
                    Placeholder="What did you work on?" />

            <Label Text="Date" FontAttributes="Bold" />
            <DatePicker x:Name="DatePickerCtl" Format="ddd, MMM d, yyyy" />

            <Label Text="Duration (minutes)" FontAttributes="Bold" />
            <Entry x:Name="DurationEntry" Keyboard="Numeric" Placeholder="e.g. 30" />

            <Label x:Name="ProjectLabel" Text="Project" FontAttributes="Bold" />
            <Picker x:Name="ProjectPicker" Title="No project" />

            <Label x:Name="TaskLabel" Text="Task" FontAttributes="Bold" />
            <Picker x:Name="TaskPicker" Title="No task" />

            <Label x:Name="ErrorLabel" IsVisible="False" TextColor="{StaticResource Error}" />

            <Button x:Name="SaveButton" Text="Save" Clicked="OnSaveClicked"
                    BackgroundColor="{StaticResource Primary}" TextColor="White" />

            <Button x:Name="DeleteButton" Text="Delete" Clicked="OnDeleteClicked"
                    IsVisible="False" BackgroundColor="{StaticResource Error}" TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
