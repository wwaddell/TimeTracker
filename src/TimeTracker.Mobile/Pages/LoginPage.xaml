<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TimeTracker.Mobile.Pages.LoginPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             Title="Sign in">
    <Grid RowDefinitions="*,Auto,*" Padding="32">
        <VerticalStackLayout Grid.Row="1" Spacing="24" HorizontalOptions="Center">
            <Image Source="applogo.png" HeightRequest="96" WidthRequest="96" HorizontalOptions="Center" />
            <Label Text="TimeTracker" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="Log time and manage tasks on the go."
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"
                   TextColor="{StaticResource Gray500}" />

            <ActivityIndicator x:Name="Busy" IsRunning="False" IsVisible="False" HorizontalOptions="Center" />

            <Label x:Name="ErrorLabel" IsVisible="False" TextColor="{StaticResource Error}"
                   HorizontalTextAlignment="Center" />

            <Button x:Name="SignInButton" Text="Sign in" Clicked="OnSignInClicked"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    WidthRequest="220" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
